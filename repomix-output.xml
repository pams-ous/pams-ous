            <th>Last Update</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="taskTableBody"></tbody>
      </table>
    </div>
  </div>
</main>

<!-- ADD TASK -->
<div class="modal-backdrop" id="addTaskModal" onclick="handleBackdrop(event,'addTaskModal')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h3><i class="fa-solid fa-plus"></i> Add New Task</h3>
      <button class="modal-close" onclick="closeModal('addTaskModal')"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
      <div class="form-row single">
        <div class="form-group"><label>Task Name *</label><input type="text" id="add-name" placeholder="Enter task name" /></div>
      </div>
      <div class="form-row single">
        <div class="form-group"><label>Description</label><textarea id="add-desc" placeholder="Optional description..."></textarea></div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Priority *</label>
          <select id="add-priority">
            <option value="">— Select —</option>
            <option value="URGENT">URGENT</option>
            <option value="HIGH">HIGH</option>
            <option value="MEDIUM">MEDIUM</option>
            <option value="LOW">LOW</option>
          </select>
        </div>
        <div class="form-group">
          <label>Status *</label>
          <select id="add-status">
            <option value="PENDING">PENDING</option>
            <option value="IN PROGRESS">IN PROGRESS</option>
            <option value="COMPLETED">COMPLETED</option>
            <option value="CANCELLED">CANCELLED</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Due Date *</label><input type="date" id="add-due" /></div>
        <div class="form-group">
          <label>Assign To</label>
          <select id="add-assignee"><option value="">— Select assignee —</option></select>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal('addTaskModal')">Cancel</button>
      <button class="btn-primary" onclick="addTask()"><i class="fa-solid fa-plus"></i> Add Task</button>
    </div>
  </div>
</div>

<!-- LOG UPDATE -->
<div class="modal-backdrop" id="logUpdateModal" onclick="handleBackdrop(event,'logUpdateModal')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h3><i class="fa-solid fa-pen-to-square"></i> Log Update</h3>
      <button class="modal-close" onclick="closeModal('logUpdateModal')"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
      <div class="form-row single">
        <div class="form-group">
          <label>Select Task *</label>
          <select id="log-task-select"><option value="">— Select a task —</option></select>
        </div>
      </div>
      <div class="form-row single">
        <div class="form-group">
          <label>Update Notes *</label>
          <textarea id="log-notes" placeholder="Describe what was accomplished or updated..." style="min-height:100px;"></textarea>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Change Status</label>
          <select id="log-new-status">
            <option value="">— Keep current —</option>
            <option value="PENDING">PENDING</option>
            <option value="IN PROGRESS">IN PROGRESS</option>
            <option value="COMPLETED">COMPLETED</option>
            <option value="CANCELLED">CANCELLED</option>
          </select>
        </div>
        <div class="form-group">
          <label>Attachment URL (optional)</label>
          <input type="text" id="log-attachment" placeholder="https://..." />
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal('logUpdateModal')">Cancel</button>
      <button class="btn-primary" onclick="saveLogUpdate()"><i class="fa-solid fa-floppy-disk"></i> Save Update</button>
    </div>
  </div>
</div>

<!-- VIEW TASK -->
<div class="modal-backdrop" id="viewTaskModal" onclick="handleBackdrop(event,'viewTaskModal')">
  <div class="modal wide" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h3><i class="fa-solid fa-eye"></i> Task Details</h3>
      <button class="modal-close" onclick="closeModal('viewTaskModal')"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body" id="viewTaskBody"></div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal('viewTaskModal')">Close</button>
      <button class="btn-secondary" onclick="openEditFromView()"><i class="fa-solid fa-pen"></i> Edit</button>
    </div>
  </div>
</div>

<!-- EDIT TASK -->
<div class="modal-backdrop" id="editTaskModal" onclick="handleBackdrop(event,'editTaskModal')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h3><i class="fa-solid fa-pen"></i> Edit Task</h3>
      <button class="modal-close" onclick="closeModal('editTaskModal')"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-id" />
      <div class="form-row single"><div class="form-group"><label>Task Name *</label><input type="text" id="edit-name" /></div></div>
      <div class="form-row single"><div class="form-group"><label>Description</label><textarea id="edit-desc"></textarea></div></div>
      <div class="form-row">
        <div class="form-group">
          <label>Priority *</label>
          <select id="edit-priority">
            <option value="URGENT">URGENT</option>
            <option value="HIGH">HIGH</option>
            <option value="MEDIUM">MEDIUM</option>
            <option value="LOW">LOW</option>
          </select>
        </div>
        <div class="form-group">
          <label>Status *</label>
          <select id="edit-status">
            <option value="PENDING">PENDING</option>
            <option value="IN PROGRESS">IN PROGRESS</option>
            <option value="COMPLETED">COMPLETED</option>
            <option value="CANCELLED">CANCELLED</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Due Date *</label><input type="date" id="edit-due" /></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal('editTaskModal')">Cancel</button>
      <button class="btn-primary" onclick="saveEditTask()"><i class="fa-solid fa-floppy-disk"></i> Save Changes</button>
    </div>
  </div>
</div>

<!-- DELETE -->
<div class="modal-backdrop" id="deleteModal" onclick="handleBackdrop(event,'deleteModal')">
  <div class="modal" style="width:420px;" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h3><i class="fa-solid fa-triangle-exclamation"></i> Remove Task</h3>
      <button class="modal-close" onclick="closeModal('deleteModal')"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="confirm-body">
      <i class="fa-solid fa-trash-can"></i>
      <p>Are you sure you want to remove<br /><strong id="deleteTaskName"></strong>?<br /><br />This action cannot be undone.</p>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal('deleteModal')">Cancel</button>
      <button class="btn-primary" style="background:#dc2626;" onclick="confirmDelete()"><i class="fa-solid fa-trash-can"></i> Remove</button>
    </div>
  </div>
</div>

<script src="../js/api.js"></script>
<script>
const { apiFetch, requireAuth, setupChrome, fmtDate, fmtHeaderDate, getUser } = PAMS;

let tasks = [];
let users = [];
let deleteTarget = null;
let viewTarget   = null;

document.addEventListener('DOMContentLoaded', async () => {
  if (!requireAuth()) return;
  setupChrome();
  document.getElementById('pageDate').textContent = fmtHeaderDate();
  await Promise.all([loadTasks(), loadUsers()]);
});

async function loadTasks() {
  try {
    const me = getUser();
    const { tasks: rows } = await apiFetch(`/tasks/me?email=${encodeURIComponent(me.email)}`);
    tasks = rows;
    renderTasks();
  } catch (err) {
    console.error('Load tasks failed:', err);
  }
}

async function loadUsers() {
  try {
    const { users: rows } = await apiFetch('/users');
    users = rows;
    // Fill the "Assign To" select with options
    const sel = document.getElementById('add-assignee');
    sel.innerHTML = '<option value="">— Select assignee —</option>' +
      users.map(u => `<option value="${u.email}">${u.name || u.email}</option>`).join('');
  } catch (err) {
    console.error('Load users failed:', err);
  }
}

function isOverdue(t) {
  if (t.status === 'COMPLETED' || t.status === 'CANCELLED') return false;
  return new Date(t.dueDate) < new Date(new Date().toDateString());
}

function priorityBadge(p) {
  const map = { URGENT:'p-urgent', HIGH:'b-high', MEDIUM:'b-medium', LOW:'b-low' };
  return `<span class="badge ${map[p] || ''}">${p}</span>`;
}
function statusBadge(s) {
  const map = { 'COMPLETED':'b-completed','IN PROGRESS':'b-inprogress','PENDING':'b-pending','CANCELLED':'b-cancelled' };
  return `<span class="badge ${map[s] || ''}">${s}</span>`;
}

function renderTasks() {
  const tbody = document.getElementById('taskTableBody');
  const overdueTasks = tasks.filter(isOverdue);

  // Update alert banner
  const banner = document.getElementById('alertBanner');
  if (overdueTasks.length > 0) {
    document.getElementById('alertText').textContent =
      `${overdueTasks.length} task${overdueTasks.length > 1 ? 's are' : ' is'} overdue.`;
    banner.classList.remove('hidden');
  } else {
    banner.classList.add('hidden');
  }

  if (tasks.length === 0) {
    tbody.innerHTML = `<tr><td colspan="7"><div class="empty-state"><i class="fa-regular fa-clipboard"></i>No tasks assigned to you.</div></td></tr>`;
    return;
  }

  tbody.innerHTML = tasks.map((t, i) => {
    const overdue = isOverdue(t);
    return `
      <tr class="${overdue ? 'task-overdue' : ''}">
        <td>${i + 1}</td>
        <td class="task-name">${t.title}${overdue ? '<span class="overdue-tag">OVERDUE</span>' : ''}</td>
        <td>${priorityBadge(t.priority)}</td>
        <td>${statusBadge(t.status)}</td>
        <td>${fmtDate(t.dueDate)}</td>
        <td>${fmtDate(t.updatedAt)}</td>
        <td>
          <div class="action-wrap">
            <button class="act-btn act-view"   title="View"   onclick="openViewTask(${t.id})"><i class="fa-solid fa-eye"></i></button>
            <button class="act-btn act-edit"   title="Edit"   onclick="openEditTask(${t.id})"><i class="fa-solid fa-pen"></i></button>
            <button class="act-btn act-delete" title="Remove" onclick="openDeleteTask(${t.id})"><i class="fa-solid fa-trash-can"></i></button>
          </div>
        </td>
      </tr>`;
  }).join('');
}

function scrollToOverdue() {
  document.querySelector('.panel').scrollIntoView({ behavior: 'smooth' });
}

// ─── Add Task ─────────────────────────────────────────────────────
async function addTask() {
  const title       = document.getElementById('add-name').value.trim();
  const description = document.getElementById('add-desc').value.trim();
  const priority    = document.getElementById('add-priority').value;
  const status      = document.getElementById('add-status').value;
  const dueDate     = document.getElementById('add-due').value;
  const assignee    = document.getElementById('add-assignee').value;

  if (!title || !priority || !dueDate) { alert('Please fill in Task Name, Priority, and Due Date.'); return; }

  const me = getUser();
  try {
    await apiFetch('/tasks', 'POST', {
      title, description, priority, status, dueDate,
      assignedByEmail: me.email,
      assigneeEmail:   assignee || me.email
    });
    closeModal('addTaskModal');
    ['add-name','add-desc','add-due'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('add-priority').value = '';
    document.getElementById('add-status').value = 'PENDING';
    await loadTasks();
  } catch (err) {
    alert('Failed to create task: ' + err.message);
  }
}

// ─── View Task ────────────────────────────────────────────────────
async function openViewTask(id) {
  viewTarget = id;
  try {
    const { task: t, updates } = await apiFetch(`/tasks/${id}`);
    const overdue = isOverdue(t);
    const logsHtml = updates.length
      ? updates.map(l => `
          <div class="log-entry">
            <span class="log-date">${fmtDate(l.logged_at)}</span>
            <span class="log-note">${l.updated_text || ''}${l.status_change ? ` <em>(${l.status_change})</em>` : ''}</span>
          </div>`).join('')
      : '<p class="log-empty">No updates logged yet.</p>';

    document.getElementById('viewTaskBody').innerHTML = `
      <div class="detail-grid">
        <div class="detail-item full"><label>Task Name</label><div class="val">${t.title}${overdue ? ' <span class="overdue-tag">OVERDUE</span>' : ''}</div></div>
        <div class="detail-item"><label>Priority</label><div class="val">${priorityBadge(t.priority)}</div></div>
        <div class="detail-item"><label>Status</label><div class="val">${statusBadge(t.status)}</div></div>
        <div class="detail-item"><label>Due Date</label><div class="val">${fmtDate(t.dueDate)}</div></div>
        <div class="detail-item"><label>Assigned By</label><div class="val">${t.assignedByName || '—'}</div></div>
        ${t.description ? `<div class="detail-item full"><label>Description</label><div class="val" style="color:#6b7280;font-weight:400;">${t.description}</div></div>` : ''}
      </div>
      <div class="update-log">
        <div class="update-log-title"><i class="fa-solid fa-clock-rotate-left"></i> Update Log</div>
        ${logsHtml}
      </div>`;
    openModal('viewTaskModal');
  } catch (err) {
    alert('Failed to load task: ' + err.message);
  }
}

function openEditFromView() {
  closeModal('viewTaskModal');
  if (viewTarget) openEditTask(viewTarget);
}

// ─── Edit ─────────────────────────────────────────────────────────
function openEditTask(id) {
  const t = tasks.find(x => x.id === id);
  if (!t) return;
  document.getElementById('edit-id').value         = t.id;
  document.getElementById('edit-name').value       = t.title;
  document.getElementById('edit-desc').value       = t.description || '';
  document.getElementById('edit-priority').value   = t.priority;
  document.getElementById('edit-status').value     = t.status;
  document.getElementById('edit-due').value        = (t.dueDate || '').slice(0, 10);
  openModal('editTaskModal');
}

async function saveEditTask() {
  const id = parseInt(document.getElementById('edit-id').value);
  const title       = document.getElementById('edit-name').value.trim();
  const description = document.getElementById('edit-desc').value.trim();
  const priority    = document.getElementById('edit-priority').value;
  const status      = document.getElementById('edit-status').value;
  const dueDate     = document.getElementById('edit-due').value;
  if (!title || !dueDate) { alert('Task Name and Due Date are required.'); return; }

  try {
    await apiFetch(`/tasks/${id}`, 'PUT', { title, description, priority, status, dueDate });
    closeModal('editTaskModal');
    await loadTasks();
  } catch (err) {
    alert('Failed to update task: ' + err.message);
  }
}

// ─── Delete ───────────────────────────────────────────────────────
function openDeleteTask(id) {
  const t = tasks.find(x => x.id === id);
  if (!t) return;
  deleteTarget = id;
  document.getElementById('deleteTaskName').textContent = `"${t.title}"`;
  openModal('deleteModal');
}

async function confirmDelete() {
  try {
    await apiFetch(`/tasks/${deleteTarget}`, 'DELETE');
    deleteTarget = null;
    closeModal('deleteModal');
    await loadTasks();
  } catch (err) {
    alert('Failed to delete task: ' + err.message);
  }
}

// ─── Log Update ───────────────────────────────────────────────────
function openModal(id) {
  if (id === 'logUpdateModal') {
    const sel = document.getElementById('log-task-select');
    sel.innerHTML = '<option value="">— Select a task —</option>' +
      tasks.filter(t => t.status !== 'CANCELLED').map(t =>
        `<option value="${t.id}">${t.title}</option>`).join('');
    document.getElementById('log-notes').value      = '';
    document.getElementById('log-new-status').value = '';
    document.getElementById('log-attachment').value = '';
  }
  document.getElementById(id).classList.add('open');
}
function closeModal(id)         { document.getElementById(id).classList.remove('open'); }
function handleBackdrop(e, id)  { if (e.target === document.getElementById(id)) closeModal(id); }

async function saveLogUpdate() {
  const taskId   = parseInt(document.getElementById('log-task-select').value);
  const notes    = document.getElementById('log-notes').value.trim();
  const statusCh = document.getElementById('log-new-status').value;
  const attach   = document.getElementById('log-attachment').value.trim();

  if (!taskId) { alert('Please select a task.'); return; }
  if (!notes)  { alert('Please enter update notes.'); return; }

  const me = getUser();
  try {
    await apiFetch('/task-updates', 'POST', {
      taskId, email: me.email,
      notes,
      statusChange:  statusCh || null,
      attachmentUrl: attach || null
    });
    closeModal('logUpdateModal');
    await loadTasks();
  } catch (err) {
    alert('Failed to log update: ' + err.message);
  }
}
</script>
</body>
</html>
</file>

<file path="branched-out-build/frontend/pages/reports.html">
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PUP OUS — Reports</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="../css/styles.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-star"><img src="../assets/pup-ou-logo.png" alt="PUP Logo"
        onerror="this.onerror=null;this.src='../assets/pup-logo.png';" /></div>
    <div>
      <div class="brand-name">PUP OUS</div>
      <div class="brand-sub">Accomplishment System</div>
    </div>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-label">Main</div>
    <a class="nav-item" href="dashboard.html"><i class="fas fa-th-large"></i> Dashboard</a>
    <a class="nav-item" href="task-board.html"><i class="fas fa-table-list"></i> Task Board</a>
    <a class="nav-item" href="my-tasks.html"><i class="fas fa-clipboard-list"></i> My Tasks</a>

    <div class="nav-label" data-admin-only>Management</div>
    <a class="nav-item active" href="reports.html"      data-admin-only><i class="fas fa-chart-bar"></i> Reports</a>
    <a class="nav-item"        href="users-groups.html" data-admin-only><i class="fas fa-users"></i> Users &amp; Groups</a>
  </nav>

  <div class="sidebar-user">
    <div class="user-row">
      <div class="user-avatar">?</div>
      <div>
        <div class="user-name">—</div>
        <div class="user-role">—</div>
      </div>
    </div>
    <button class="logout-btn" onclick="PAMS.logout()"><i class="fas fa-right-from-bracket"></i> Logout</button>
  </div>
</aside>

<!-- MAIN -->
<main class="main">

  <div class="alert-banner hidden" id="alertBanner">
    <i class="fas fa-circle-exclamation"></i>
    <span id="alertText"></span> <a href="my-tasks.html">View Tasks</a>
  </div>

  <div class="page-header">
    <div class="header-left">
      <div>
        <h1>Reports</h1>
        <p>Generate and view accomplishment reports</p>
      </div>
    </div>
    <div class="header-right">
      <span class="date-text" id="headerDate"></span>
      <div class="notif-wrap">
        <button class="icon-btn" title="Notifications">
          <i class="fas fa-bell"></i><span class="notif-dot"></span>
        </button>
        <div class="notif-popover">
          <div class="notif-header">Notifications</div>
          <div class="notif-body"></div>
        </div>
      </div>
      <button class="btn-primary" onclick="openGenerateModal()"><i class="fas fa-file-circle-plus"></i> New Report</button>
    </div>
  </div>

  <div class="content">
    <div class="action-row">
      <button class="btn-primary" onclick="openGenerateModal()"><i class="fas fa-file-alt"></i> Generate Report</button>
      <button class="btn-outline" onclick="window.print()"><i class="fas fa-print"></i> Print</button>
    </div>

    <div class="report-layout">

      <!-- History -->
      <div class="history-panel">
        <div class="panel-heading"><i class="fas fa-list"></i> Report History</div>
        <div id="historyList"></div>
      </div>

      <!-- Preview -->
      <div class="preview-panel">
        <div class="preview-header">
          <div class="preview-logo"><img src="../assets/pup-ou-logo.png" alt="PUP Logo"
              onerror="this.onerror=null;this.src='../assets/pup-logo.png';" /></div>
          <div>
            <div class="preview-org">PUP &ndash; OPEN UNIVERSITY SYSTEM</div>
            <div class="preview-title" id="previewTitle">No report selected</div>
            <div class="preview-period" id="previewPeriod">Generate or select a report</div>
          </div>
        </div>

        <div class="preview-body">
          <div class="stats-row">
            <div class="stat-card"><div class="stat-num c-gray"  id="statTotal">0</div><div class="stat-label">Total Tasks</div></div>
            <div class="stat-card"><div class="stat-num c-green" id="statCompleted">0</div><div class="stat-label">Completed</div></div>
            <div class="stat-card"><div class="stat-num c-blue"  id="statInProgress">0</div><div class="stat-label">In Progress</div></div>
          </div>

          <div class="section-label">Task Breakdown</div>
          <table class="task-table" id="taskTable">
            <thead>
              <tr><th>Task</th><th>Assignee</th><th>Status</th><th>Priority</th></tr>
            </thead>
            <tbody id="taskBody"></tbody>
          </table>

          <div class="chart-wrap"><canvas id="statusChart"></canvas></div>
        </div>
      </div>

    </div>
  </div>
</main>

<!-- GENERATE REPORT MODAL -->
<div class="modal-backdrop" id="genModal" onclick="if(event.target===this)this.classList.remove('open')">
  <div class="modal">
    <div class="modal-header">
      <h3><i class="fas fa-file-circle-plus"></i> Generate Report</h3>
      <button class="modal-close" onclick="document.getElementById('genModal').classList.remove('open')"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <div class="form-group">
          <label>Report Type *</label>
          <select id="gen-type">
            <option value="Daily">Daily</option>
            <option value="Weekly" selected>Weekly</option>
            <option value="Annual">Annual</option>
          </select>
        </div>
        <div class="form-group">
          <label>Scope *</label>
          <select id="gen-scope" onchange="onScopeChange()">
            <option value="All" selected>All (System-Wide)</option>
            <option value="Group">Group</option>
            <option value="Individual">Individual</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Period Start *</label>
          <input type="date" id="gen-start" />
        </div>
        <div class="form-group">
          <label>Period End *</label>
          <input type="date" id="gen-end" />
        </div>
      </div>
      <div class="form-group" id="gen-group-wrap" style="display:none;">
        <label>Group</label>
        <select id="gen-group"></select>
      </div>
      <div class="form-group" id="gen-user-wrap" style="display:none;">
        <label>Employee *</label>
        <!-- Searchable employee picker. Type to filter; click a row to pick.
             The selected employee's email is persisted in #gen-user-email. -->
        <div class="user-search">
          <input type="text" id="gen-user-search" autocomplete="off"
                 placeholder="Type a name or email…" oninput="filterUserResults()">
          <input type="hidden" id="gen-user-email">
          <div class="user-search-results" id="gen-user-results"></div>
          <div class="user-search-picked" id="gen-user-picked" style="display:none;">
            <i class="fa-solid fa-user-check"></i>
            <span id="gen-user-picked-name">—</span>
            <button type="button" class="link-btn" onclick="clearPickedUser()">change</button>
          </div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="document.getElementById('genModal').classList.remove('open')">Cancel</button>
      <button class="btn-primary" onclick="generateReport()"><i class="fas fa-file-alt"></i> Generate</button>
    </div>
  </div>
</div>

<script src="../js/api.js"></script>
<script>
const { apiFetch, requireAuth, setupChrome, fmtDate, fmtHeaderDate, getUser } = PAMS;

let reports = [];
let activeReportId = null;
let chart;
let allUsers = [];   // cached for the individual-scope autocomplete

document.addEventListener('DOMContentLoaded', async () => {
  if (!requireAuth()) return;
  setupChrome();
  document.getElementById('headerDate').textContent = fmtHeaderDate();
  await loadReports();
});

async function loadReports() {
  try {
    const data = await apiFetch('/reports');
    reports = data.reports;
    renderHistory();
    if (reports.length > 0) await selectReport(reports[0].id);
  } catch (err) {
    console.error('Load reports failed:', err);
  }
}

function renderHistory() {
  const list = document.getElementById('historyList');
  if (reports.length === 0) {
    list.innerHTML = '<div class="empty-state" style="padding:20px;"><i class="fas fa-inbox"></i>No reports yet.</div>';
    return;
  }
  list.innerHTML = reports.map(r => `
    <div class="report-card ${r.id === activeReportId ? 'active' : ''}" onclick="selectReport(${r.id})">
      <div class="report-card-title"><i class="fas fa-file-alt"></i> ${r.title}</div>
      <div class="report-card-meta">
        Generated: ${new Date(r.generatedAt).toLocaleString()}
        ${r.generatedByName ? ` &middot; By: ${r.generatedByName}` : ''}
      </div>
    </div>
  `).join('');
}

async function selectReport(id) {
  activeReportId = id;
  renderHistory();
  try {
    const { report, tasks, stats } = await apiFetch(`/reports/${id}`);
    document.getElementById('previewTitle').textContent  = report.title;
    document.getElementById('previewPeriod').textContent = `Period: ${report.period} | Scope: ${report.scopeLabel}`;
    document.getElementById('statTotal').textContent      = stats.total;
    document.getElementById('statCompleted').textContent  = stats.completed;
    document.getElementById('statInProgress').textContent = stats.inProgress;

    const statusMap = { 'COMPLETED':'b-completed', 'IN PROGRESS':'b-inprogress', 'PENDING':'b-pending', 'CANCELLED':'b-cancelled' };
    const prioMap   = { 'URGENT':'p-urgent', 'HIGH':'p-high', 'MEDIUM':'p-medium', 'LOW':'p-low' };

    document.getElementById('taskBody').innerHTML = tasks.length === 0
      ? '<tr><td colspan="4" style="text-align:center;color:#9ca3af;padding:24px;">No tasks in this report.</td></tr>'
      : tasks.map(t => `
          <tr>
            <td>${t.title}</td>
            <td>${t.assignee}</td>
            <td><span class="badge ${statusMap[t.status] || ''}">${t.status}</span></td>
            <td><span class="badge ${prioMap[t.priority] || ''}">${t.priority}</span></td>
          </tr>`).join('');

    const data = [stats.pending, stats.inProgress, stats.completed, stats.cancelled];
    if (chart) {
      chart.data.datasets[0].data = data;
      chart.update();
    } else {
      chart = new Chart(document.getElementById('statusChart').getContext('2d'), {
        type: 'bar',
        data: {
          labels: ['Pending', 'In Progress', 'Completed', 'Cancelled'],
          datasets: [{ data, backgroundColor: ['#F5A623','#3B82F6','#22C55E','#CBD5E1'], borderRadius: 5, borderSkipped: false }]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            y: { beginAtZero: true, ticks: { stepSize: 1, color: '#6b7280' }, grid: { color: '#f0f0f0' } },
            x: { ticks: { color: '#6b7280' }, grid: { display: false } }
          }
        }
      });
    }
  } catch (err) {
    console.error('Load report failed:', err);
  }
}

// ─── Generate ────────────────────────────────────────────────────
async function openGenerateModal() {
  // Default the date range to "this week"
  const today = new Date();
  const monday = new Date(today);
  monday.setDate(today.getDate() - ((today.getDay() + 6) % 7));
  document.getElementById('gen-start').value = monday.toISOString().slice(0, 10);
  document.getElementById('gen-end').value   = today.toISOString().slice(0, 10);

  // Fill group dropdown and pre-cache the user list for the individual picker.
  try {
    const [g, u] = await Promise.all([apiFetch('/groups'), apiFetch('/users')]);
    document.getElementById('gen-group').innerHTML = g.groups.map(x => `<option value="${x.id}">${x.name}</option>`).join('');
    allUsers = u.users || [];
    filterUserResults();   // seed with top results
  } catch {}

  clearPickedUser();
  onScopeChange();
  document.getElementById('genModal').classList.add('open');
}

function onScopeChange() {
  const scope = document.getElementById('gen-scope').value;
  document.getElementById('gen-group-wrap').style.display = scope === 'Group'      ? 'flex' : 'none';
  document.getElementById('gen-user-wrap').style.display  = scope === 'Individual' ? 'flex' : 'none';
}

// ── Searchable employee picker (Individual scope) ──────────────────────
// Live-filters allUsers as the admin types; clicking a result records its
// email in the hidden field and collapses the results list into a picked-chip.
function filterUserResults() {
  const q   = (document.getElementById('gen-user-search').value || '').trim().toLowerCase();
  const box = document.getElementById('gen-user-results');
  if (!allUsers.length) {
    box.innerHTML = `<div class="user-search-empty">No users loaded.</div>`;
    return;
  }
  const matches = (q
    ? allUsers.filter(u =>
        (u.name  || '').toLowerCase().includes(q) ||
        (u.email || '').toLowerCase().includes(q) ||
        (u.code  || '').toLowerCase().includes(q))
    : allUsers
  ).slice(0, 8);

  if (matches.length === 0) {
    box.innerHTML = `<div class="user-search-empty">No matches.</div>`;
    return;
  }
  box.innerHTML = matches.map(u => `
    <button type="button" class="user-search-item"
            onclick="pickUser('${encodeURIComponent(u.email)}','${encodeURIComponent(u.name || u.email)}')">
      <span class="avatar-sm">${escInitials(u.name || u.email)}</span>
      <span class="user-search-meta">
        <strong>${escHtml(u.name || u.email)}</strong>
        <span class="muted">${escHtml(u.email)}${u.code ? ' · ' + escHtml(u.code) : ''}</span>
      </span>
    </button>
  `).join('');
}

function pickUser(emailEnc, nameEnc) {
  const email = decodeURIComponent(emailEnc);
  const name  = decodeURIComponent(nameEnc);
  document.getElementById('gen-user-email').value = email;
  document.getElementById('gen-user-picked-name').textContent = `${name} (${email})`;
  document.getElementById('gen-user-picked').style.display = 'flex';
  document.getElementById('gen-user-search').style.display  = 'none';
  document.getElementById('gen-user-results').style.display = 'none';
}

function clearPickedUser() {
  document.getElementById('gen-user-email').value = '';
  document.getElementById('gen-user-picked').style.display = 'none';
  document.getElementById('gen-user-search').style.display  = '';
  document.getElementById('gen-user-results').style.display = '';
  document.getElementById('gen-user-search').value = '';
  filterUserResults();
}

function escHtml(s) {
  return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}
function escInitials(name) {
  return escHtml((name || '?').trim().split(/\s+/).map(w => w[0] || '').join('').slice(0, 2).toUpperCase());
}

async function generateReport() {
  const reportType = document.getElementById('gen-type').value;
  const scopeType  = document.getElementById('gen-scope').value;
  const periodStart = document.getElementById('gen-start').value;
  const periodEnd   = document.getElementById('gen-end').value;
  if (!periodStart || !periodEnd) { alert('Please set the period.'); return; }

  const me = getUser();
  const body = { reportType, scopeType, periodStart, periodEnd, generatedByEmail: me.email };
  if (scopeType === 'Group')      body.scopeGroupId  = parseInt(document.getElementById('gen-group').value);
  if (scopeType === 'Individual') {
    body.scopeUserEmail = document.getElementById('gen-user-email').value;
    if (!body.scopeUserEmail) { alert('Please pick an employee for the Individual scope.'); return; }
  }

  try {
    const data = await apiFetch('/reports', 'POST', body);
    document.getElementById('genModal').classList.remove('open');
    await loadReports();
    if (data.reportId) await selectReport(data.reportId);
  } catch (err) {
    alert('Failed to generate report: ' + err.message);
  }
}
</script>
</body>
</html>
</file>

<file path="branched-out-build/frontend/pages/task-board.html">
<!DOCTYPE html>
