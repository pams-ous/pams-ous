    <div class="logo-wrap"><img src="../assets/pup-ou-logo.png" alt="PUP OUS"
        onerror="this.onerror=null;this.src='../assets/pup-logo.png';"></div>
    <div>
      <div class="brand-name">PUP OUS</div>
      <div class="brand-sub">Accomplishment System</div>
    </div>
  </div>

  <nav class="nav-group">
    <div class="nav-label">Main</div>
    <a href="dashboard.html"  class="nav-item"><i class="fa-solid fa-table-columns"></i> Dashboard</a>
    <a href="task-board.html" class="nav-item active"><i class="fa-solid fa-table-list"></i> Task Board</a>
    <a href="my-tasks.html"   class="nav-item"><i class="fa-solid fa-clipboard-list"></i> My Tasks</a>
  </nav>

  <nav class="nav-group" data-admin-only>
    <div class="nav-label">Management</div>
    <a href="reports.html"      class="nav-item"><i class="fa-solid fa-chart-bar"></i> Reports</a>
    <a href="users-groups.html" class="nav-item"><i class="fa-solid fa-users"></i> Users &amp; Groups</a>
  </nav>

  <div class="sidebar-footer">
    <div class="user-card">
      <div class="user-avatar">?</div>
      <div>
        <div class="user-name">—</div>
        <div class="user-role">—</div>
      </div>
    </div>
    <button class="logout-btn" onclick="PAMS.logout()">
      <i class="fa-solid fa-right-from-bracket"></i> Logout
    </button>
  </div>
</aside>

<!-- MAIN -->
<div class="main">

  <div class="alert-banner hidden" id="alertBanner">
    <i class="fa-solid fa-circle-exclamation"></i>
    <span id="alertText"></span> <a href="my-tasks.html">View Tasks</a>
  </div>

  <div class="page-header">
    <div class="header-left">
      <div>
        <h1>Task Board</h1>
        <p>Manage and track all tasks</p>
      </div>
    </div>
    <div class="header-right">
      <div class="date-pill" id="headerDate"></div>
      <div class="notif-wrap">
        <button class="icon-btn" title="Notifications">
          <i class="fa-solid fa-bell"></i><span class="notif-dot"></span>
        </button>
        <div class="notif-popover">
          <div class="notif-header">Notifications</div>
          <div class="notif-body"></div>
        </div>
      </div>
      <button class="new-task-btn" onclick="openNewTask()"><i class="fa-solid fa-plus"></i> New Task</button>
    </div>
  </div>

  <!-- ────────── RIBBON ──────────
       MS-Word-style ribbon: tabs across the top toggle between sets of tools
       (Home shows filter chips, Sort changes ordering, View toggles density,
       Admin shows administrator-only actions). The active tab unfurls its
       toolbar in the row below — same vertical real-estate, contextual tools.
  -->
  <div class="tb-ribbon">
    <div class="ribbon-tabs" id="ribbonTabs">
      <button class="ribbon-tab active" data-tab="home">Home</button>
      <button class="ribbon-tab"        data-tab="filters">Filters</button>
      <button class="ribbon-tab"        data-tab="sort">Sort</button>
      <button class="ribbon-tab"        data-tab="view">View</button>
      <button class="ribbon-tab" data-admin-only data-tab="admin">Admin</button>
    </div>

    <!-- HOME — status chips that double as the active "tab" of tasks -->
    <div class="ribbon-panel active" data-panel="home">
      <div class="ribbon-group">
        <div class="ribbon-group-label">Status</div>
        <div class="status-tabs" id="statusTabs">
          <button class="status-tab active" data-status="ALL">All <span class="cnt" data-cnt="ALL">0</span></button>
          <button class="status-tab" data-status="PENDING">Pending <span class="cnt" data-cnt="PENDING">0</span></button>
          <button class="status-tab" data-status="IN PROGRESS">In Progress <span class="cnt" data-cnt="IN PROGRESS">0</span></button>
