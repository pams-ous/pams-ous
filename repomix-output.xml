/* ── HELPERS ──────────────────────────────────────── */
function userName(id) {
  const u = USERS.find(x => x.user_id === id);
  return u ? `${u.first_name} ${u.last_name}` : '—';
}
function userInitials(id) {
  const u = USERS.find(x => x.user_id === id);
  return u ? `${u.first_name[0]}${u.last_name[0]}` : '??';
}
function userShortName(id) {
  const u = USERS.find(x => x.user_id === id);
  if (!u) return '—';
  const first = u.first_name.split(' ')[0];
  return `${first} ${u.last_name}`;
}
function groupName(id) {
  const g = GROUPS.find(x => x.group_id === id);
  return g ? g.group_name : '—';
}
function formatDate(d) {
  if (!d) return '—';
  const dt = new Date(d);
  return dt.toLocaleDateString('en-PH', { month:'short', day:'numeric', year:'numeric' });
}
function isOverdue(task) {
  if (!task.due_date || task.status === 'completed' || task.status === 'cancelled') return false;
  return new Date(task.due_date) < new Date();
}
function badge(val, prefix='') { return `<span class="badge badge-${prefix}${val}">${val.replace('_',' ')}</span>`; }

/* ── TOAST ────────────────────────────────────────── */
function toast(msg, type='info') {
  const tc = document.getElementById('toast-container');
  const t = document.createElement('div');
  t.className = `toast ${type}`;
  t.textContent = msg;
  tc.appendChild(t);
  setTimeout(() => t.remove(), 3200);
}

/* ── MODAL ────────────────────────────────────────── */
function openModal(id) { document.getElementById(id).classList.remove('hidden'); }
function closeModal(id) { document.getElementById(id).classList.add('hidden'); }
document.querySelectorAll('.modal-overlay').forEach(mo => {
  mo.addEventListener('click', e => { if (e.target === mo) mo.classList.add('hidden'); });
});

/* ── LOGIN ────────────────────────────────────────── */
function handleLogin(e) {
  e.preventDefault();
  const email = document.getElementById('login-email').value.trim();
  const user = USERS.find(u => u.email === email && u.is_active);
  if (!user) { toast('Invalid credentials or inactive account.', 'error'); return; }
  currentUser = user;
  initApp();
}

function handleLogout() {
  currentUser = null;
  document.getElementById('login-page').classList.remove('hidden');
  document.getElementById('app').classList.add('hidden');
}

/* ── APP INIT ─────────────────────────────────────── */
function initApp() {
  document.getElementById('login-page').classList.add('hidden');
  document.getElementById('app').classList.remove('hidden');

  // Header date
  document.getElementById('header-date').textContent =
    new Date().toLocaleDateString('en-PH', { weekday:'short', month:'long', day:'numeric', year:'numeric' });

  // Sidebar user info
  document.getElementById('sidebar-name').textContent = userName(currentUser.user_id);
  document.getElementById('sidebar-role').textContent = currentUser.role === 'admin' ? 'Administrator' : 'Member';
  document.getElementById('sidebar-avatar').textContent = userInitials(currentUser.user_id);

  // Admin-only elements
  const isAdmin = currentUser.role === 'admin';
  document.querySelectorAll('.admin-only').forEach(el => {
    el.style.display = isAdmin ? '' : 'none';
  });
  if (!isAdmin) {
    document.getElementById('header-action-btn').style.display = 'none';
    document.getElementById('admin-label').style.display = 'none';
  }

  // Populate selects
  populateSelects();
  // Render views
  renderDashboard();
  renderBoard();
  renderMyTasks();
  renderUsers();
  renderGroups();
  renderReports();
  navigate('dashboard');
}

/* ── NAVIGATION ───────────────────────────────────── */
function navigate(view) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));

  const viewEl = document.getElementById(`view-${view}`);
  if (viewEl) viewEl.classList.add('active');

  const navItem = document.querySelector(`.nav-item[onclick="navigate('${view}')"]`);
  if (navItem) navItem.classList.add('active');

  const titles = {
    'dashboard': ['Dashboard', `Welcome back, ${currentUser?.first_name}`],
    'tasks':     ['Task Board', 'Manage and track all tasks'],
    'my-tasks':  ['My Tasks', 'Your assigned tasks'],
    'reports':   ['Reports', 'Generate and view accomplishment reports'],
    'users':     ['Users & Groups', 'Manage system users and groups'],
  };
  const [t, s] = titles[view] || ['Dashboard', ''];
  document.getElementById('page-title').textContent = t;
  document.getElementById('page-sub').textContent = s;

  const btn = document.getElementById('header-action-btn');
  if (currentUser?.role === 'admin') {
    if (view === 'tasks') { btn.innerHTML='<i class="fas fa-plus"></i> New Task'; btn.onclick=showAddTask; btn.style.display=''; }
    else if (view === 'reports') { btn.innerHTML='<i class="fas fa-file-alt"></i> New Report'; btn.onclick=()=>openModal('modal-gen-report'); btn.style.display=''; }
    else if (view === 'users') { btn.innerHTML='<i class="fas fa-user-plus"></i> Add User'; btn.onclick=()=>openModal('modal-add-user'); btn.style.display=''; }
    else { btn.innerHTML='<i class="fas fa-plus"></i> Add Task'; btn.onclick=showAddTask; btn.style.display=''; }
  }

  if (view === 'dashboard') setTimeout(renderCharts, 100);
  if (view === 'reports' && REPORTS.length) selectReport(REPORTS[0]);
}

/* ── POPULATE SELECTS ─────────────────────────────── */
function populateSelects() {
  const members = USERS.filter(u => u.role === 'member' && u.is_active);
  const memberOpts = members.map(u => `<option value="${u.user_id}">${userName(u.user_id)}</option>`).join('');
  const groupOpts  = GROUPS.map(g => `<option value="${g.group_id}">${g.group_name}</option>`).join('');

  document.getElementById('t-user').innerHTML = `<option value="">— Select —</option>${memberOpts}`;
  document.getElementById('t-group').innerHTML = `<option value="">— Select —</option>${groupOpts}`;
  document.getElementById('filter-assignee').innerHTML = `<option value="">All Assignees</option>${memberOpts}`;
  document.getElementById('lu-task').innerHTML = TASKS.filter(t => t.status !== 'completed' && t.status !== 'cancelled')
    .map(t => `<option value="${t.task_id}">${t.title}</option>`).join('');
  document.getElementById('nu-group').innerHTML = `<option value="">— None —</option>${groupOpts}`;
}

/* ── DASHBOARD ────────────────────────────────────── */
function renderDashboard() {
  // Activity feed
  const feed = document.getElementById('activity-feed');
  const dotColor = { in_progress:'blue', completed:'green', pending:'yellow', cancelled:'red' };
  feed.innerHTML = [...TASK_UPDATES].reverse().slice(0,6).map(u => `
    <div class="activity-item">
      <div class="activity-dot ${dotColor[u.status_change] || 'blue'}"></div>
      <div style="flex:1">
        <div class="activity-text"><strong>${userName(u.updated_by)}</strong>: ${u.update_text}</div>
        <div class="activity-time"><i class="fas fa-clock"></i> ${u.logged_at}</div>
      </div>
    </div>`).join('');

  // Group progress
  const gp = document.getElementById('group-progress');
  gp.innerHTML = GROUPS.map(g => {
    const gTasks = TASKS.filter(t => t.assigned_to_group === g.group_id ||
      GROUP_MEMBERS.filter(m => m.group_id === g.group_id).some(m => m.user_id === t.assigned_to_user));
    const total = gTasks.length || 1;
    const done  = gTasks.filter(t => t.status === 'completed').length;
    const pct   = Math.round(done / total * 100);
    return `<div>
      <div style="display:flex;justify-content:space-between;margin-bottom:.3rem">
        <span style="font-size:.82rem;font-weight:600">${g.group_name}</span>
        <span style="font-size:.78rem;color:var(--maroon);font-weight:600">${pct}%</span>
      </div>
      <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:${pct}%"></div></div>
      <div style="font-size:.7rem;color:var(--gray-500);margin-top:.15rem">${done} / ${total} tasks completed</div>
    </div>`;
  }).join('');
}

function renderCharts() {
  // Destroy existing
  if (chartStatus) { chartStatus.destroy(); chartStatus = null; }
  if (chartPriority) { chartPriority.destroy(); chartPriority = null; }

  const ctxS = document.getElementById('chart-status');
  const ctxP = document.getElementById('chart-priority');
  if (!ctxS || !ctxP) return;

  const statuses = ['pending','in_progress','completed','cancelled'];
  const colors   = ['#ffc107','#007bff','#28a745','#6c757d'];

  chartStatus = new Chart(ctxS, {
    type:'bar',
    data: {
      labels: GROUPS.map(g => g.group_name),
      datasets: statuses.map((s,i) => ({
        label: s.replace('_',' '),
        data: GROUPS.map(g => TASKS.filter(t =>
          t.status === s && (t.assigned_to_group === g.group_id ||
          GROUP_MEMBERS.filter(m=>m.group_id===g.group_id).some(m=>m.user_id===t.assigned_to_user))
        ).length),
        backgroundColor: colors[i],
        borderRadius: 4,
      }))
    },
    options: {
      responsive:true, maintainAspectRatio:false,
      plugins: { legend:{ position:'bottom', labels:{ font:{size:11}, boxWidth:14 } } },
      scales: { x:{ stacked:true, grid:{display:false} }, y:{ stacked:true, ticks:{stepSize:1} } }
    }
  });

  const pCounts = ['low','medium','high','urgent'].map(p => TASKS.filter(t=>t.priority===p).length);
  chartPriority = new Chart(ctxP, {
    type:'doughnut',
    data: {
      labels:['Low','Medium','High','Urgent'],
      datasets:[{ data:pCounts, backgroundColor:['#6c757d','#007bff','#fd7e14','#dc3545'], borderWidth:2 }]
    },
    options: {
      responsive:true, maintainAspectRatio:false,
      plugins: { legend:{ position:'bottom', labels:{ font:{size:11}, boxWidth:14 } } }
    }
  });
}

/* ── TASK BOARD ───────────────────────────────────── */
function renderBoard() {
  const gf = document.getElementById('filter-group').value;
  const pf = document.getElementById('filter-priority').value;
  const af = document.getElementById('filter-assignee').value;

  let tasks = [...TASKS];
  if (gf) tasks = tasks.filter(t => String(t.assigned_to_group) === gf ||
    GROUP_MEMBERS.filter(m=>m.group_id===Number(gf)).some(m=>m.user_id===t.assigned_to_user));
  if (pf) tasks = tasks.filter(t => t.priority === pf);
  if (af) tasks = tasks.filter(t => String(t.assigned_to_user) === af);

  const cols = ['pending','in_progress','completed','cancelled'];
  const colLabels = { pending:'Pending', in_progress:'In Progress', completed:'Completed', cancelled:'Cancelled' };

  document.getElementById('kanban-board').innerHTML = cols.map(col => {
    const colTasks = tasks.filter(t => t.status === col);
    return `<div class="kanban-col">
      <div class="kanban-col-header ${col}">
        <span class="kanban-col-title">${colLabels[col]}</span>
        <span class="kanban-count">${colTasks.length}</span>
      </div>
      ${colTasks.map(t => `
        <div class="task-card priority-${t.priority}" onclick="showTaskDetail(${t.task_id})">
          <div class="task-card-title">${t.title}</div>
          <div class="task-card-desc">${(t.description||'').slice(0,75)}${t.description?.length>75?'…':''}</div>
          <div class="task-card-meta">
            <div class="task-assignee">
              <div class="mini-avatar">${t.assigned_to_user?userInitials(t.assigned_to_user):t.assigned_to_group?'G'+t.assigned_to_group:'?'}</div>
              ${t.assigned_to_user?userShortName(t.assigned_to_user):t.assigned_to_group?groupName(t.assigned_to_group):'Unassigned'}
            </div>
            <div style="display:flex;align-items:center;gap:.4rem">
              ${badge(t.priority)}
              <span class="task-due${isOverdue(t)?' overdue':''}">
                <i class="fas fa-calendar-alt"></i> ${formatDate(t.due_date)}${isOverdue(t)?' ⚠':''}
              </span>
            </div>
          </div>
        </div>`).join('')}
    </div>`;
  }).join('');
}

function clearFilters() {
  ['filter-group','filter-priority','filter-assignee'].forEach(id => document.getElementById(id).value = '');
  renderBoard();
}

/* ── MY TASKS ─────────────────────────────────────── */
function renderMyTasks() {
  const myTasks = TASKS.filter(t =>
    t.assigned_to_user === currentUser?.user_id ||
    GROUP_MEMBERS.filter(m => m.user_id === currentUser?.user_id).some(m => m.group_id === t.assigned_to_group)
  );
  const tbody = document.getElementById('my-tasks-body');
  tbody.innerHTML = myTasks.map(t => {
    const lastUpd = TASK_UPDATES.filter(u => u.task_id === t.task_id).at(-1);
    return `<tr>
      <td>${t.task_id}</td>
      <td><strong>${t.title}</strong></td>
      <td>${badge(t.priority)}</td>
      <td>${badge(t.status,'')}</td>
      <td class="${isOverdue(t)?'color-maroon':''}">${formatDate(t.due_date)}${isOverdue(t)?'<i class="fas fa-exclamation-circle" style="margin-left:.3rem"></i>':''}</td>
      <td style="font-size:.78rem;color:var(--gray-500)">${lastUpd ? lastUpd.logged_at : '—'}</td>
      <td>
        <button class="btn btn-primary btn-sm" onclick="showLogUpdateFor(${t.task_id})">
          <i class="fas fa-pen"></i> Log
        </button>
        <button class="btn btn-ghost btn-sm" onclick="showTaskDetail(${t.task_id})" style="margin-left:.3rem">
          <i class="fas fa-eye"></i>
        </button>
      </td>
    </tr>`;
  }).join('') || '<tr><td colspan="7" style="text-align:center;color:var(--gray-500);padding:2rem">No tasks assigned.</td></tr>';
}

/* ── TASK DETAIL ──────────────────────────────────── */
function showTaskDetail(taskId) {
  const t = TASKS.find(x => x.task_id === taskId);
  if (!t) return;
  currentTaskId = taskId;
  document.getElementById('td-title').innerHTML = `<i class="fas fa-info-circle"></i> ${t.title}`;
  document.getElementById('td-status').innerHTML = badge(t.status,'');
  document.getElementById('td-priority').innerHTML = badge(t.priority);
  document.getElementById('td-assigned').textContent = t.assigned_to_user ? userName(t.assigned_to_user) : t.assigned_to_group ? groupName(t.assigned_to_group) : 'Unassigned';
  document.getElementById('td-due').innerHTML = `${formatDate(t.due_date)}${isOverdue(t)?' <span style="color:#dc3545;font-size:.75rem">(Overdue)</span>':''}`;
  document.getElementById('td-desc').textContent = t.description || '(No description)';

  const updates = TASK_UPDATES.filter(u => u.task_id === taskId);
  document.getElementById('td-updates').innerHTML = updates.length ?
    updates.map(u => `<div class="update-entry">
      <div class="update-entry-user">${userName(u.updated_by)}${u.status_change?` → ${badge(u.status_change,'')}`:''}</div>
      <div class="update-entry-text">${u.update_text}</div>
      <div class="update-entry-time"><i class="fas fa-clock"></i> ${u.logged_at}</div>
    </div>`).join('') :
    '<p style="font-size:.82rem;color:var(--gray-500)">No updates logged yet.</p>';

  openModal('modal-task-detail');
}

/* ── ADD TASK ─────────────────────────────────────── */
function showAddTask() {
  document.getElementById('t-title').value = '';
  document.getElementById('t-desc').value = '';
  document.getElementById('t-due').value = '';
  openModal('modal-add-task');
}

function addTask() {
  const title = document.getElementById('t-title').value.trim();
  if (!title) { toast('Please enter a task title.', 'error'); return; }
  const newTask = {
    task_id: TASKS.length + 1,
    title,
    description: document.getElementById('t-desc').value,
    assigned_by: currentUser.user_id,
    assigned_to_user: Number(document.getElementById('t-user').value) || null,
    assigned_to_group: Number(document.getElementById('t-group').value) || null,
    priority: document.getElementById('t-priority').value,
    status: 'pending',
    due_date: document.getElementById('t-due').value || null,
    created_at: new Date().toISOString(), updated_at: new Date().toISOString(),
  };
  TASKS.push(newTask);
  closeModal('modal-add-task');
  renderBoard();
  renderMyTasks();
  toast('Task created successfully!', 'success');
}

/* ── LOG UPDATE ───────────────────────────────────── */
function showLogUpdate() { openModal('modal-log-update'); }
function showLogUpdateFor(taskId) {
  closeModal('modal-task-detail');
  document.getElementById('lu-task').value = taskId;
  openModal('modal-log-update');
}

function logUpdate() {
  const taskId = Number(document.getElementById('lu-task').value);
  const text = document.getElementById('lu-text').value.trim();
  if (!text) { toast('Please enter your accomplishment.', 'error'); return; }
  const statusChange = document.getElementById('lu-status').value;

  TASK_UPDATES.push({
    update_id: TASK_UPDATES.length + 1,
    task_id: taskId,
    updated_by: currentUser.user_id,
    update_text: text,
    status_change: statusChange || null,
    logged_at: new Date().toLocaleString('en-PH'),
  });

  if (statusChange) {
    const t = TASKS.find(x => x.task_id === taskId);
    if (t) t.status = statusChange;
  }

  document.getElementById('lu-text').value = '';
  document.getElementById('lu-status').value = '';
  closeModal('modal-log-update');
  renderBoard();
  renderMyTasks();
  renderDashboard();
  toast('Accomplishment logged!', 'success');
}

/* ── REPORTS ──────────────────────────────────────── */
function renderReports() {
  const list = document.getElementById('report-list');
  list.innerHTML = REPORTS.map(r => `
    <div class="report-item" id="ritem-${r.report_id}" onclick="selectReport(${JSON.stringify(r).split('"').join("'")})">
      <div class="report-item-title">
        <i class="fas fa-file-alt" style="color:var(--maroon)"></i>
        ${r.report_type.charAt(0).toUpperCase()+r.report_type.slice(1)} Report
        ${r.scope_type==='group'?`— ${groupName(r.scope_group_id)}`:r.scope_type==='individual'?`— ${userName(r.scope_user_id)}`:''}
      </div>
      <div class="report-item-meta">
        Generated: ${r.generated_at} &nbsp;·&nbsp; By: ${userName(r.generated_by)}
      </div>
    </div>`).join('');
}

function selectReport(r) {
  if (typeof r === 'string') r = JSON.parse(r.replace(/'/g,'"'));
  document.querySelectorAll('.report-item').forEach(el => el.classList.remove('selected'));
  const el = document.getElementById(`ritem-${r.report_id}`);
  if (el) el.classList.add('selected');

  document.getElementById('rp-title').textContent =
    `${r.report_type.charAt(0).toUpperCase()+r.report_type.slice(1)} Accomplishment Report`;
  document.getElementById('rp-period').textContent =
    `Period: ${formatDate(r.period_start)} – ${formatDate(r.period_end)} | Scope: ${r.scope_type.toUpperCase()}`;

  const rTasks = TASKS.slice(0, 8);
  const completed = rTasks.filter(t=>t.status==='completed').length;
  const inprog    = rTasks.filter(t=>t.status==='in_progress').length;
  const pending   = rTasks.filter(t=>t.status==='pending').length;

  document.getElementById('rp-stats').innerHTML = `
    <div class="report-stat-box"><div class="val">${rTasks.length}</div><div class="lbl">Total Tasks</div></div>
    <div class="report-stat-box"><div class="val" style="color:#28a745">${completed}</div><div class="lbl">Completed</div></div>
    <div class="report-stat-box"><div class="val" style="color:var(--gold)">${inprog}</div><div class="lbl">In Progress</div></div>`;

  document.getElementById('rp-tbody').innerHTML = rTasks.map(t => `
    <tr><td>${t.title}</td><td>${t.assigned_to_user?userName(t.assigned_to_user):t.assigned_to_group?groupName(t.assigned_to_group):'—'}</td>
    <td>${badge(t.status,'')}</td><td>${badge(t.priority)}</td></tr>`).join('');

  if (chartReport) { chartReport.destroy(); chartReport = null; }
  const ctx = document.getElementById('chart-report');
  chartReport = new Chart(ctx, {
    type:'bar',
    data:{
      labels:['Pending','In Progress','Completed','Cancelled'],
      datasets:[{
        label:'Tasks',
        data:[pending,inprog,completed,0],
        backgroundColor:['#ffc107','#007bff','#28a745','#6c757d'],
        borderRadius:4
      }]
    },
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{ticks:{stepSize:1}}}}
  });
}

function generateReport() {
  const newR = {
    report_id: REPORTS.length + 1,
    report_type: document.getElementById('rp-type').value,
    generated_by: currentUser.user_id,
    scope_type: document.getElementById('rp-scope').value,
    period_start: document.getElementById('rp-start').value,
    period_end: document.getElementById('rp-end').value,
    generated_at: new Date().toLocaleString('en-PH'),
  };
  REPORTS.unshift(newR);
  closeModal('modal-gen-report');
  renderReports();
  selectReport(newR);
  toast('Report generated!', 'success');
}

function printReport() { window.print(); }

/* ── USERS ────────────────────────────────────────── */
function renderUsers() {
  document.getElementById('users-body').innerHTML = USERS.map(u => `
    <tr>
      <td><strong>${u.first_name} ${u.last_name}</strong></td>
      <td style="font-size:.78rem">${u.email}</td>
      <td>${badge(u.role)}</td>
      <td>${u.is_active?'<span class="badge badge-completed">Active</span>':'<span class="badge badge-cancelled">Inactive</span>'}</td>
      <td>
        <button class="btn btn-ghost btn-sm" onclick="toggleUser(${u.user_id})">
          <i class="fas fa-${u.is_active?'ban':'check'}"></i>
        </button>
      </td>
    </tr>`).join('');
}

function toggleUser(uid) {
  const u = USERS.find(x => x.user_id === uid);
  if (!u || u.user_id === currentUser?.user_id) { toast("You can't deactivate yourself.", 'error'); return; }
  u.is_active = !u.is_active;
  renderUsers();
  toast(`${u.first_name} ${u.last_name} ${u.is_active?'activated':'deactivated'}.`, 'info');
}

function addUser() {
  const first = document.getElementById('nu-first').value.trim();
  const last  = document.getElementById('nu-last').value.trim();
  const email = document.getElementById('nu-email').value.trim();
  if (!first || !last || !email) { toast('Please fill all required fields.', 'error'); return; }
  const newUser = {
    user_id: USERS.length + 1,
    first_name: first, last_name: last, email,
    role: document.getElementById('nu-role').value,
    is_active: true,
  };
  USERS.push(newUser);
  const gid = Number(document.getElementById('nu-group').value);
  if (gid) GROUP_MEMBERS.push({ id:GROUP_MEMBERS.length+1, group_id:gid, user_id:newUser.user_id, role_in_group:'member', joined_at:new Date().toISOString() });
  closeModal('modal-add-user');
  renderUsers();
  renderGroups();
  populateSelects();
  toast(`User ${first} ${last} added.`, 'success');
}

/* ── GROUPS ───────────────────────────────────────── */
function renderGroups() {
  document.getElementById('groups-body').innerHTML = GROUPS.map(g => {
    const members = GROUP_MEMBERS.filter(m => m.group_id === g.group_id);
    const leader  = members.find(m => m.role_in_group === 'leader');
    return `<tr>
      <td><strong>${g.group_name}</strong><br><span style="font-size:.72rem;color:var(--gray-500)">${g.description||''}</span></td>
      <td>${members.length}</td>
      <td style="font-size:.82rem">${leader ? userName(leader.user_id) : '—'}</td>
      <td><button class="btn btn-ghost btn-sm"><i class="fas fa-edit"></i></button></td>
    </tr>`;
  }).join('');
}

function addGroup() {
  const name = document.getElementById('ng-name').value.trim();
  if (!name) { toast('Please enter a group name.', 'error'); return; }
  GROUPS.push({ group_id:GROUPS.length+1, group_name:name, description:document.getElementById('ng-desc').value });
  closeModal('modal-add-group');
  renderGroups();
  populateSelects();
  toast(`Group "${name}" created.`, 'success');
}

/* ── NOTIFICATIONS ────────────────────────────────── */
function showNotifications() {
  const overdue = TASKS.filter(isOverdue);
  toast(`${overdue.length} overdue task(s). ${TASK_UPDATES.length} recent updates.`, 'info');
}

/* ── INIT DATE ────────────────────────────────────── */
document.getElementById('header-date').textContent =
  new Date().toLocaleDateString('en-PH', { weekday:'short', month:'long', day:'numeric', year:'numeric' });
</script>
</body>
</html>
</file>

