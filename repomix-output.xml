<file path="frontend/css/style.css">
/* 
   Project: PUP OUS – Personnel Daily Accomplishment Report System
   Version: 0.1.0-alpha
*/

@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');
@import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css');

.no-transition,
.no-transition * {
  transition: none !important;
}

/* ─── VARIABLES ────────────────────────────────────── */
:root {
  /* Brand Colors */
  --maroon: #800000;
  --dark-maroon: #5a0000;
  --deep-maroon: #3d0000;
  --maroon-hover: #5a0000;

  --gold: #DAA520;
  --light-gold: #FFD700;
  --pale-gold: #fff3cd;
  --gold-hover: #b8860b;

  /* Neutrals */
  --white: #ffffff;
  --off-white: #f8f4f4;
  --gray-100: #f4f4f4;
  --gray-200: #e9ecef;
  --gray-500: #6c757d;
  --gray-700: #495057;
  --text: #2d2d2d;

  /* Layout & Accents */
  --sidebar-w: 260px;
  --sb-w-collapsed: 72px;
  --sb-w-expanded: 260px;
  --sb-bg: linear-gradient(180deg, #3d0510 0%, #6B0A1A 35%, #a8000d 100%);
  --sb-accent: #ffd700;
  --header-h: 64px;
  --radius: 10px;
  --radius-lg: 24px;
  --shadow: 0 2px 12px rgba(0, 0, 0, .10);
  --shadow-lg: 0 4px 24px rgba(0, 0, 0, .15);
  --transition: all 0.2s ease-in-out;

  /* Status Colors */
  --red-bg: #fde8e8;
  --red-border: #f5b8b8;
  --red-text: #b91c1c;
  --green-bg: #dcfce7;
  --green-text: #15803d;
  --blue-bg: #dbeafe;
  --blue-text: #1d4ed8;
  --amber-bg: #fef3c7;
  --amber-text: #92400e;

  /* Target build variables */
  --pup-maroon: #6B0A1A;
  --pup-maroon-dark: #5a0816;
  --red-danger: #dc2626;
  --text-primary: #1a1a2e;
  --text-secondary: #374151;
  --text-muted: #6b7280;
  --text-faint: #9ca3af;
  --border-light: #e5e7eb;
  --border-lighter: #f0f0f0;
}

/* ─── RESET & BASE ────────────────────────────────── */
*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html,
body {
  overflow-x: hidden;
}

body {
  font-family: 'Poppins', sans-serif;
  background: var(--off-white);
  color: var(--text);
  min-height: 100vh;
  display: flex;
}

/* ─── UTILITY ─────────────────────────────────────── */
.hidden {
  display: none !important;
}

.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-between {
  justify-content: space-between;
}

.gap-1 {
  gap: .25rem;
}

.gap-2 {
  gap: .5rem;
}

.gap-3 {
  gap: .75rem;
}

.gap-4 {
  gap: 1rem;
}

.mt-1 {
  margin-top: .25rem;
}

.mt-2 {
  margin-top: .5rem;
}

.mt-3 {
  margin-top: .75rem;
}

.mt-4 {
  margin-top: 1rem;
}

.mb-3 {
  margin-bottom: 1rem;
}

.mb-4 {
  margin-bottom: 1.5rem;
}

.pt-3 {
  padding-top: 0.75rem;
}

.ph-24 {
  padding-left: 24px;
  padding-right: 24px;
}

.ph-32 {
  padding-left: 32px;
  padding-right: 32px;
}

.mh-24 {
  margin-left: 24px;
  margin-right: 24px;
}

.mh-32 {
  margin-left: 32px;
  margin-right: 32px;
}

.w-full {
  width: 100%;
}

.d-block {
  display: block;
}

.text-sm {
  font-size: .85rem;
}

.text-xs {
  font-size: .75rem;
}

.text-center {
  text-align: center;
}

.text-left {
  text-align: left;
}

.fw-500 {
  font-weight: 500;
}

.fw-600 {
  font-weight: 600;
}

.fw-700 {
  font-weight: 700;
}

.color-maroon {
  color: var(--maroon);
}

.color-gold {
  color: var(--gold);
}

.color-gray {
  color: var(--gray-500);
}

.no-underline {
  text-decoration: none;
}

.uppercase {
  text-transform: uppercase;
}

.letter-spacing-1 {
  letter-spacing: 1px;
}

.border-top {
  border-top: 1px solid var(--gray-200);
}

.flex-80 {
  flex: 0 0 80px;
}

/* ─── COMPONENTS ──────────────────────────────────── */

/* Buttons */
.btn,
.portal-btn {
  transition: var(--transition);
  cursor: pointer;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  font-family: inherit;
  font-size: .875rem;
  font-weight: 500;
  border: none;
}

.btn:hover,
.portal-btn:hover {
  transform: scale(1.02);
}

.btn {
  padding: .5rem 1.1rem;
  border-radius: var(--radius);
}

.btn-primary {
  background: var(--maroon);
  color: var(--white);
}

.btn-primary:hover {
  background: var(--maroon-hover);
}

.btn-gold {
  background: var(--gold);
  color: var(--white);
}

.btn-gold:hover {
  background: var(--gold-hover);
}

.btn-outline {
  background: transparent;
  color: var(--maroon);
  border: 1.5px solid var(--maroon);
}

.btn-outline:hover {
  background: var(--maroon);
  color: var(--white);
}

/* Forms */
.form-group {
  display: flex;
  flex-direction: column;
  gap: .3rem;
  margin-bottom: 1rem;
}

.form-row {
  display: flex;
  gap: 1rem;
}

.form-row .form-group {
  flex: 1;
}

.form-label {
  font-size: .82rem;
  font-weight: 500;
  color: var(--gray-700);
  text-align: left;
}

.form-control {
  width: 100%;
  padding: .55rem .85rem;
  border: 1.5px solid var(--gray-200);
  border-radius: 8px;
  font-family: inherit;
  font-size: .875rem;
  color: var(--text);
  background: var(--white);
  transition: border-color .15s ease;
  outline: none;
}

.password-field-wrap {
  position: relative;
  width: 100%;
}

.password-field-wrap .pass-toggle {
  position: absolute;
  right: 12px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  cursor: pointer;
  color: var(--gray-500);
  padding: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: var(--transition);
}

.password-field-wrap .pass-toggle:hover {
  color: var(--maroon);
}

.password-field-wrap .form-control {
  padding-right: 2.5rem;
}

.form-control:focus {
  border-color: var(--maroon);
}

/* Badges */
.badge {
  display: inline-block;
  padding: 2px 10px;
  border-radius: 20px;
  font-size: .72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .4px;
}

.badge-pending {
  background: #fff3cd;
  color: #856404;
}

.badge-in_progress {
  background: #cce5ff;
  color: #004085;
}

.badge-completed {
  background: #d4edda;
  color: #155724;
}

.badge-cancelled {
  background: #f8d7da;
  color: #721c24;
}

.badge-urgent {
  background: #f8d7da;
  color: #721c24;
}

.badge-admin {
  background: var(--pale-gold);
  color: var(--dark-maroon);
}

/* Tables */
.table-wrap {
  overflow-x: auto;
  margin-top: 1rem;
}

table {
  width: 100%;
  border-collapse: collapse;
}

thead tr {
  background: var(--maroon);
  color: var(--white);
}

thead th {
  padding: .75rem 1rem;
  text-align: left;
  font-size: .82rem;
  font-weight: 500;
}

tbody tr {
  border-bottom: 1px solid var(--gray-200);
}

tbody tr:hover {
  background: var(--off-white);
}

tbody td {
  padding: .7rem 1rem;
  font-size: .875rem;
}

/* Data Table (Advanced) */
.data-table {
  width: 100%;
  border-collapse: collapse;
  background: #fff;
}

.data-table th {
  background: #f9fafb;
  padding: 12px 16px;
  text-align: left;
  font-size: 12px;
  font-weight: 600;
  color: var(--gray-500);
  text-transform: uppercase;
  border-bottom: 1px solid var(--gray-200);
}

.data-table td {
  padding: 14px 16px;
  border-bottom: 1px solid var(--gray-100);
  font-size: 14px;
}

.data-table tbody tr:hover {
  background: #fcfcfc;
}

/* Modals */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, .45);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}

.modal {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow-lg);
  width: 100%;
  max-width: 560px;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.1rem 1.5rem;
  background: var(--maroon);
  color: var(--white);
  border-radius: var(--radius) var(--radius) 0 0;
}

/* Panels */
.panel {
  background: #fff;
  border-radius: 12px;
  box-shadow: var(--shadow);
  border: 1px solid var(--gray-200);
  min-width: 0;
  /* Prevents panel from growing past grid container */
  display: flex;
  flex-direction: column;
}

.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid var(--gray-100);
  flex-shrink: 0;
}

.panel-title {
  font-weight: 600;
  font-size: 15px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.panel-title i {
  color: var(--maroon);
}

/* ─── SIDEBAR ────────────────────────────────────── */

.sidebar {
  width: var(--sb-w-collapsed);
  min-height: 100vh;
  background: var(--sb-bg);
  display: flex;
  flex-direction: column;
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  z-index: 1100;
  transition: width 0.28s cubic-bezier(.2, .7, .2, 1);
  box-shadow: 4px 0 16px rgba(0, 0, 0, 0.18);
  overflow-x: visible;
  overflow-y: hidden;
}

body.sidebar-open .sidebar {
  width: var(--sb-w-expanded);
}

.sidebar-brand {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 18px 12px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  min-height: 84px;
  position: relative;
}

.logo-star {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: #fff;
  border: 2px solid rgba(255, 255, 255, 0.65);
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 3px;
  margin-left: 4px;
}

.logo-star img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.sidebar-brand>div:not(.logo-star):not(.sidebar-toggle) {
  opacity: 0;
  width: 0;
  overflow: hidden;
  white-space: nowrap;
  pointer-events: none;
  transition: opacity 0.18s, width 0.28s cubic-bezier(.2, .7, .2, 1);
}

body.sidebar-open .sidebar-brand>div:not(.logo-star):not(.sidebar-toggle) {
  opacity: 1;
  width: auto;
  pointer-events: auto;
}

.brand-name {
  color: var(--sb-accent);
  font-size: 15px;
  font-weight: 700;
  line-height: 1.2;
  text-transform: uppercase;
}

.brand-sub {
  color: rgba(255, 255, 255, 0.72);
  font-size: 11px;
  margin-top: 2px;
}

.sidebar-toggle {
  position: absolute;
  top: 42px;
  right: 0;
  transform: translate(75%, -50%);
  width: 22px;
  height: 22px;
  border: none;
  background: #fff;
  color: var(--pup-maroon);
  font-size: 10px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 5px;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.25);
  transition: background 0.15s, color 0.15s, transform 0.28s cubic-bezier(.2, .7, .2, 1);
  z-index: 1101;
}

.sidebar-toggle:hover {
  background: var(--sb-accent);
  color: var(--pup-maroon);
}

body.sidebar-open .sidebar-toggle {
  transform: translate(75%, -50%) rotate(180deg);
}

.nav-group {
  flex: 0 0 auto;
  padding: 8px 0 0;
}

body:not(.sidebar-open) .nav-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.nav-label {
  display: none;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 14px;
  margin: 4px 10px;
  padding: 10px 12px;
  color: rgba(255, 255, 255, 0.8);
  font-size: 14px;
  cursor: pointer;
  text-decoration: none;
  white-space: nowrap;
  border-radius: 8px;
  border: 1.5px solid transparent;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
}

.nav-item i {
  width: 22px;
  text-align: center;
  font-size: 16px;
  flex-shrink: 0;
  color: inherit;
}

.nav-item:hover {
  background: rgba(255, 255, 255, 0.08);
  color: #fff;
}

.nav-item.active {
  background: rgba(255, 215, 0, 0.06);
  color: var(--sb-accent);
  font-weight: 600;
  border-color: var(--sb-accent);
}

body:not(.sidebar-open) .nav-item {
  width: 44px;
  height: 44px;
  margin: 0;
  padding: 0;
  gap: 0;
  font-size: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

body:not(.sidebar-open) .nav-item i {
  font-size: 17px;
}

.sidebar-footer {
  padding: 14px 12px;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
  margin-top: auto;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 10px;
}

body:not(.sidebar-open) .user-card {
  justify-content: center;
}

.user-avatar {
  width: 40px;
  height: 40px;
  background: rgba(220, 220, 220, 0.85);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 14px;
  color: var(--pup-maroon);
  flex-shrink: 0;
}

.user-card>div:not(.user-avatar) {
  opacity: 0;
  width: 0;
  overflow: hidden;
  white-space: nowrap;
  pointer-events: none;
  transition: opacity 0.18s, width 0.28s cubic-bezier(.2, .7, .2, 1);
}

body.sidebar-open .user-card>div:not(.user-avatar) {
  opacity: 1;
  width: auto;
  pointer-events: auto;
}

.user-name {
  color: #fff;
  font-size: 14px;
  font-weight: 600;
  line-height: 1.2;
}

.user-role {
  color: rgba(255, 255, 255, 0.55);
  font-size: 12px;
}

.logout-btn {
  display: flex;
  align-items: center;
  gap: 14px;
  width: 100%;
  padding: 10px 12px;
  background: transparent;
  border: 1.5px solid transparent;
  border-radius: 8px;
  color: rgba(255, 255, 255, 0.8);
  font-size: 13px;
  font-family: inherit;
  cursor: pointer;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
}

.logout-btn i {
  width: 22px;
  text-align: center;
  font-size: 16px;
  flex-shrink: 0;
}

.logout-btn:hover {
  background: rgba(255, 255, 255, 0.08);
  color: #fff;
  border-color: rgba(255, 255, 255, 0.2);
}

body:not(.sidebar-open) .logout-btn {
  width: 44px;
  height: 44px;
  margin: 0 auto;
  padding: 0;
  gap: 0;
  font-size: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

body:not(.sidebar-open) .logout-btn i {
  font-size: 17px;
}

/* ─── MAIN CONTENT ────────────────────────────────── */

.main {
  margin-left: var(--sb-w-collapsed);
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-gutter: stable;
  transition: margin-left 0.28s cubic-bezier(.2, .7, .2, 1);
}

body.sidebar-open .main {
  margin-left: var(--sb-w-expanded);
}

/* ─── PAGE: AUTH & LOGIN ─────────────────────────── */

.login-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--deep-maroon) 0%, var(--maroon) 50%, #a00000 100%);
  padding: 1rem;
}

.login-box {
  background: var(--white);
  border-radius: 16px;
  box-shadow: 0 8px 40px rgba(0, 0, 0, .35);
  padding: 2.5rem 2rem;
  width: 100%;
  max-width: 420px;
  height: 650px;
  max-height: 90vh;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow-y: auto;
  scrollbar-gutter: stable;
  scrollbar-width: thin;
  scrollbar-color: var(--gray-200) transparent;
}

.login-box form {
  width: 100%;
}

/* Custom scrollbar */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-thumb {
  background-color: var(--gray-200);
  border-radius: 10px;
}

::-webkit-scrollbar-thumb:hover {
  background-color: var(--gray-500);
}

.login-logo {
  width: 90px;
  height: 90px;
  object-fit: contain;
  margin-bottom: .75rem;
}

.back-link {
  text-decoration: none;
  text-align: left;
}

.auth-toggle {
  display: flex;
  background: var(--gray-100);
  border-radius: var(--radius);
  padding: 0.25rem;
  margin-bottom: 2rem;
  width: 100%;
}

.auth-toggle button {
  flex: 1;
  padding: 0.5rem;
  border: none;
  background: transparent;
  font-family: inherit;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--gray-500);
  cursor: pointer;
  border-radius: 8px;
  transition: var(--transition);
}

.auth-toggle button.active {
  background: var(--white);
  color: var(--maroon);
  box-shadow: var(--shadow);
}

/* ─── PAGE: MAIN LANDING ──────────────────────────── */

.main-landing {
  min-height: 100vh;
  background: url('../assets/ous_building.webp') no-repeat center center/cover;
  display: flex;
  justify-content: flex-end;
  align-items: stretch;
  overflow: hidden;
}

.landing-sidebar {
  background: var(--white);
  width: 100%;
  max-width: 450px;
  height: 100vh;
  border-radius: var(--radius-lg) 0 0 var(--radius-lg);
  box-shadow: -4px 0 24px rgba(0, 0, 0, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 4rem 3rem;
  animation: slideInRight 0.6s ease-out;
}

@keyframes slideInRight {
  from {
    transform: translateX(50px);
    opacity: 0;
  }

  to {
    transform: translateX(0);
    opacity: 1;
  }
}

.landing-seal {
  width: 120px;
  margin-bottom: 1.5rem;
}

.landing-branding h1 {
  font-size: 1.25rem;
  color: var(--maroon);
  line-height: 1.2;
}

.landing-branding p {
  font-size: 0.85rem;
  color: var(--gray-500);
  margin-top: 0.25rem;
}

.portal-selection {
  margin-top: auto;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  width: 80%;
}

.portal-btn {
  padding: 1rem;
  border-radius: var(--radius);
  text-align: center;
  font-weight: 600;
  justify-content: center;
  gap: 0.75rem;
}

.portal-btn-admin {
  background: var(--maroon);
  color: var(--white);
}

.portal-btn-admin:hover {
  background: var(--maroon-hover);
}

.portal-btn-personnel {
  background: var(--gold);
  color: var(--white);
}

.portal-btn-personnel:hover {
  background: var(--gold-hover);
}

/* ─── PAGE: DASHBOARD & INTERNAL ───────────────────── */

.content {
  padding: 24px 32px;
  flex: 1;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.page-header h1 {
  font-size: 24px;
  font-weight: 700;
  color: var(--text);
}

.page-header p {
  font-size: 14px;
  color: var(--gray-500);
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16px;
}

.header-date {
  font-size: 13px;
  font-weight: 500;
  color: var(--gray-500);
}

/* Stat Grid */
.stat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin-bottom: 24px;
}

.stat-card {
  background: #fff;
  padding: 20px;
  border-radius: 12px;
  display: flex;
  gap: 16px;
  border: 1px solid var(--gray-200);
  border-left-width: 4px;
  box-shadow: var(--shadow);
}

.stat-card.s-total {
  border-left-color: var(--maroon);
}

.stat-card.s-done {
  border-left-color: #16a34a;
}

.stat-card.s-progress {
  border-left-color: #f59e0b;
}

.stat-card.s-overdue {
  border-left-color: #dc2626;
}

.stat-icon-wrap {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

.s-total .stat-icon-wrap {
  background: #fff1f2;
  color: var(--maroon);
}

.s-done .stat-icon-wrap {
  background: #f0fdf4;
  color: #16a34a;
}

.s-progress .stat-icon-wrap {
  background: #fffbeb;
  color: #f59e0b;
}

.s-overdue .stat-icon-wrap {
  background: #fef2f2;
  color: #dc2626;
}

.stat-num {
  font-size: 28px;
  font-weight: 700;
  line-height: 1.1;
}

.stat-lbl {
  font-size: 12px;
  font-weight: 500;
  color: var(--gray-500);
  margin-top: 4px;
}

/* Charts Layout */
.charts-row,
.bottom-row {
  display: grid;
  gap: 20px;
  margin-bottom: 24px;
}

.charts-row {
  grid-template-columns: 1fr 340px;
}

.bottom-row {
  grid-template-columns: 1fr 380px;
}

.bar-box,
.donut-box {
  position: relative;
  height: 260px;
}

/* Accomplishments & Group Progress */
.acc-list,
.gp-list {
  padding: 20px 24px;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.acc-item {
  display: flex;
  gap: 12px;
  padding: 12px 14px;
  background: #fcfcfc;
  border-radius: 8px;
  border: 1px solid var(--gray-100);
  transition: var(--transition);
}

.acc-item:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow);
  border-color: var(--gray-200);
}

.gp-item {
  display: flex;
  flex-direction: column;
}

.gp-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 10px;
  gap: 16px;
}

.gp-name {
  font-size: 13.5px;
  font-weight: 600;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}

.gp-pct {
  font-size: 14px;
  font-weight: 700;
  color: var(--maroon);
  flex-shrink: 0;
  line-height: 1;
}

.gp-track {
  height: 8px;
  background: var(--gray-100);
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 6px;
}

.gp-fill {
  height: 100%;
  background: var(--maroon);
  border-radius: 4px;
}

.gp-sub {
  font-size: 11.5px;
  color: var(--gray-500);
  display: flex;
  justify-content: flex-end;
}

/* Notifications Popover */
.notif-wrap {
  position: relative;
}

.bell-btn {
  background: none;
  border: none;
  font-size: 18px;
  color: var(--gray-500);
  cursor: pointer;
  padding: 8px;
  border-radius: 50%;
  transition: var(--transition);
}

.bell-btn:hover {
  background: var(--gray-100);
  color: var(--maroon);
}

.notif-dot {
  position: absolute;
  top: 6px;
  right: 6px;
  width: 8px;
  height: 8px;
  background: #dc2626;
  border-radius: 50%;
  border: 2px solid #fff;
  display: none;
}

.bell-btn.has-alerts .notif-dot {
  display: block;
}

.notif-popover {
  position: absolute;
  top: calc(100% + 10px);
  right: 0;
  width: 320px;
  max-height: 400px;
  background: #fff;
  border: 1px solid var(--gray-200);
  border-radius: 12px;
  box-shadow: var(--shadow-lg);
  display: none;
  flex-direction: column;
  z-index: 1200;
}

.notif-popover.open {
  display: flex;
}

.notif-header {
  padding: 12px 16px;
  border-bottom: 1px solid var(--gray-100);
  font-weight: 700;
  font-size: 13px;
}

.notif-body {
  overflow-y: auto;
  flex: 1;
  padding: 8px 0;
}

.notif-item {
  padding: 12px 16px;
  border-bottom: 1px solid var(--gray-100);
  display: flex;
  gap: 12px;
  text-decoration: none;
  color: inherit;
  font-size: 12px;
}

.notif-item:last-child {
  border-bottom: none;
}

.notif-item:hover {
  background: #f9fafb;
}

.notif-item i {
  color: var(--maroon);
  margin-top: 2px;
}

/* ─── COMPONENTS: TASK BOARD & RIBBON ─────────────── */

.tb-ribbon {
  background: var(--white);
  border-bottom: 1px solid var(--gray-200);
  box-shadow: var(--shadow);
}

.ribbon-tabs {
  display: flex;
  background: var(--maroon);
  padding: 0 1rem;
}

.ribbon-tab {
  background: none;
  border: none;
  color: rgba(255, 255, 255, 0.7);
  padding: 10px 20px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  border-top-left-radius: 8px;
  border-top-right-radius: 8px;
  transition: var(--transition);
  margin-top: 4px;
}

.ribbon-tab:hover {
  background: rgba(255, 255, 255, 0.1);
  color: var(--white);
}

.ribbon-tab.active {
  background: var(--off-white);
  color: var(--maroon);
}

.ribbon-panel {
  display: none;
  gap: 1.5rem;
  padding: 1rem 1.5rem;
  flex-wrap: wrap;
  background: var(--white);
}

.ribbon-panel.active {
  display: flex;
}

.ribbon-group {
  display: flex;
  flex-direction: column;
  gap: .4rem;
  padding-right: 1.5rem;
  border-right: 1px solid var(--gray-100);
}

.ribbon-group:last-child {
  border-right: none;
  padding-right: 0;
}

.ribbon-group-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--gray-500);
  letter-spacing: .5px;
}

.ribbon-input {
  padding: .45rem .75rem;
  border: 1.5px solid var(--gray-200);
  border-radius: 6px;
  font-size: 13px;
  font-family: inherit;
  min-width: 180px;
  outline: none;
}

.ribbon-input:focus {
  border-color: var(--maroon);
}

.ribbon-btn {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  padding: .45rem .9rem;
  background: var(--maroon);
  color: var(--white);
  border: none;
  border-radius: 6px;
  font-size: 13px;
  cursor: pointer;
  font-family: inherit;
}

.ribbon-btn.ghost {
  background: var(--white);
  color: var(--text);
  border: 1.5px solid var(--gray-200);
}

.ribbon-btn.ghost:hover {
  background: var(--gray-100);
}

/* Status Tabs sub-navigation */
.status-tabs {
  display: inline-flex;
  border: 1.5px solid var(--gray-200);
  border-radius: 8px;
  overflow: hidden;
}

.status-tab {
  background: var(--white);
  border: none;
  border-right: 1.5px solid var(--gray-200);
  padding: .45rem 1rem;
  font-size: 12.5px;
  font-weight: 600;
  color: var(--gray-700);
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: .5rem;
  transition: var(--transition);
}

.status-tab:last-child {
  border-right: none;
}

.status-tab.active {
  background: var(--maroon);
  color: var(--white);
  border-color: var(--maroon);
}

.status-tab .cnt {
  background: var(--gray-100);
  font-size: 10px;
  padding: 1px 6px;
  border-radius: 10px;
}

.status-tab.active .cnt {
  background: rgba(255, 255, 255, 0.2);
}

/* Task Rows */
.tb-list-wrap {
  padding: 1.5rem 2rem;
  flex: 1;
}

.tb-list-header {
  margin-bottom: .75rem;
  color: var(--gray-500);
  font-size: 13px;
}

.tb-rows {
  display: flex;
  flex-direction: column;
  gap: .75rem;
}

.tb-row {
  display: flex;
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-left: 4px solid var(--maroon);
  border-radius: 8px;
  transition: var(--transition);
}

.tb-row:hover {
  box-shadow: var(--shadow);
  transform: translateX(2px);
}

.tb-row-main {
  flex: 1;
  padding: 1rem 1.25rem;
  cursor: pointer;
  min-width: 0;
}

.tb-row-top {
  display: flex;
  align-items: center;
  gap: .75rem;
  flex-wrap: wrap;
  margin-bottom: .25rem;
}

.tb-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
}

.tb-flag {
  background: var(--red-bg);
  color: var(--red-text);
  font-size: 10px;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 4px;
}

.tb-desc {
  font-size: 13px;
  color: var(--gray-700);
  margin: .25rem 0 .75rem;
}

.tb-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  font-size: 12px;
  color: var(--gray-500);
}

.tb-meta-item {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
}

.tb-row-actions {
  display: flex;
  align-items: center;
  gap: .4rem;
  padding: 0 1rem;
  border-left: 1px solid var(--gray-100);
}

.avatar-sm {
  width: 24px;
  height: 24px;
  background: var(--pale-gold);
  color: var(--maroon);
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  font-weight: 700;
}

/* Compact View */
.tb-rows.is-compact .tb-row-main {
  padding: .6rem 1rem;
}

.tb-rows.is-compact .tb-desc {
  display: none;
}

.tb-group-label {
  margin: 1.5rem 0 .5rem;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--maroon);
  letter-spacing: .5px;
}

.tb-group-count {
  margin-left: .5rem;
  color: var(--gray-500);
}

/* ─── MODALS & BACKDROPS ──────────────────────────── */

.modal-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2000;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}

.modal-backdrop.open {
  display: flex;
}

.modal-sm {
  max-width: 400px;
}

.modal-title {
  font-size: 1.1rem;
  font-weight: 700;
}

.modal-close {
  background: none;
  border: none;
  color: var(--white);
  cursor: pointer;
  font-size: 1.2rem;
}

.modal-body {
  padding: 1.5rem;
}

.modal-footer {
  padding: 1rem 1.5rem;
  border-top: 1px solid var(--gray-100);
  display: flex;
  justify-content: flex-end;
  gap: .75rem;
}

.btn-cancel {
  background: var(--gray-100);
  color: var(--gray-700);
  border: none;
  padding: .5rem 1.2rem;
  border-radius: var(--radius);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
}

.btn-danger {
  background: var(--red-text);
  color: var(--white);
  border: none;
  padding: .5rem 1.2rem;
  border-radius: var(--radius);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
}

/* View Details specific */
.view-field {
  margin-bottom: 1.25rem;
}

.view-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--gray-500);
  margin-bottom: .25rem;
}

.view-val {
  font-size: 14px;
  color: var(--text);
}

.view-actions {
  margin-top: 2rem;
  display: flex;
  gap: .75rem;
}

.act-btn {
  flex: 1;
  padding: .6rem;
  border-radius: 8px;
  border: 1.5px solid var(--gray-200);
  background: var(--white);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: .5rem;
  transition: var(--transition);
}

.act-edit:hover {
  border-color: var(--maroon);
  color: var(--maroon);
}

.act-delete:hover {
  border-color: var(--red-text);
  color: var(--red-text);
}

/* Specialized Task Tables */
.task-table {
  width: 100%;
  border-collapse: collapse;
}

.task-table thead th {
  background: var(--maroon);
  color: var(--white);
  padding: .75rem 1rem;
  text-align: left;
  font-size: 13px;
  font-weight: 500;
}

.task-table td {
  padding: .85rem 1rem;
  border-bottom: 1px solid var(--gray-100);
  font-size: 13.5px;
  vertical-align: middle;
}

.task-table tbody tr:hover td {
  background: var(--off-white);
}

.task-table thead th:first-child {
  width: 50px;
  text-align: center;
}

.task-table thead th:last-child {
  text-align: center;
}

.task-table td:first-child {
  text-align: center;
  color: var(--gray-500);
}

.task-table td:last-child {
  text-align: center;
}

.task-name {
  font-weight: 600;
  color: var(--text);
}

.task-overdue td {
  background: #fee2e2 !important;
}

.overdue-tag {
  background: #dc2626;
  color: #fff;
  font-size: 9px;
  font-weight: 800;
  padding: 1px 6px;
  border-radius: 4px;
  margin-left: 8px;
  border: 1px solid #b91c1c;
}

/* Alert Banner */
.alert-banner {
  background: #fee2e2;
  color: #dc2626;
  padding: 12px 32px;
  font-size: 13.5px;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 10px;
  border-bottom: 1px solid #fecaca;
  z-index: 1000;
}

.alert-banner i {
  font-size: 16px;
}

.alert-banner a {
  color: inherit;
  font-weight: 800;
  cursor: pointer;
  text-decoration: underline;
  margin-left: 4px;
}

.alert-banner.hidden {
  display: none !important;
}

/* Detail Grids (View Modal) */
.detail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem 1.5rem;
  margin-bottom: 1.5rem;
}

.detail-item label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--gray-500);
  display: block;
  margin-bottom: 4px;
}

.detail-item .val {
  font-size: 14px;
  color: var(--text);
  font-weight: 600;
}

.detail-item.full {
  grid-column: 1 / -1;
}

/* Update Logs */
.update-log {
  border: 1.5px solid var(--gray-100);
  border-radius: 8px;
  padding: 1rem;
  max-height: 200px;
  overflow-y: auto;
}

.update-log-title {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--gray-500);
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.log-entry {
  display: flex;
  gap: 12px;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--gray-100);
  font-size: 13px;
}

.log-entry:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.log-date {
  color: var(--gray-500);
  font-size: 11.5px;
  font-weight: 600;
  white-space: nowrap;
  min-width: 90px;
}

.log-note {
  color: var(--gray-700);
  line-height: 1.4;
}

.log-empty {
  color: var(--gray-500);
  font-size: 13px;
  font-style: italic;
  text-align: center;
  padding: 1rem;
}

/* Confirmation Bodies */
.confirm-body {
  padding: 2rem 1.5rem;
  text-align: center;
}

.confirm-body i {
  font-size: 48px;
  color: var(--red-text);
  margin-bottom: 1rem;
  display: block;
}

.confirm-body p {
  color: var(--gray-700);
  font-size: 14.5px;
  line-height: 1.6;
}

.confirm-body strong {
  color: var(--text);
  font-weight: 700;
}

/* ─── COMPONENTS: REPORTS ────────────────────────── */

.report-layout {
  display: grid;
  grid-template-columns: 310px 1fr;
  gap: 20px;
  align-items: start;
}

.history-panel {
  background: var(--white);
  border-radius: 12px;
  padding: 20px;
  box-shadow: var(--shadow);
  border: 1px solid var(--gray-200);
}

.report-card {
  border: 1.5px solid var(--gray-100);
  border-radius: 8px;
  padding: 14px 16px;
  margin-bottom: 10px;
  cursor: pointer;
  transition: var(--transition);
}

.report-card:hover {
  border-color: var(--maroon);
}

.report-card.active {
  border-color: var(--maroon);
  box-shadow: 0 0 0 1px var(--maroon);
  background: var(--off-white);
}

.report-card-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 5px;
}

.report-card-title i {
  color: var(--maroon);
  font-size: 13px;
}

.report-card-meta {
  font-size: 11.5px;
  color: var(--gray-500);
  line-height: 1.5;
}

.preview-panel {
  background: var(--white);
  border-radius: 12px;
  overflow: hidden;
  box-shadow: var(--shadow);
  border: 1px solid var(--gray-200);
}

.preview-header {
  background: var(--maroon);
  color: var(--white);
  padding: 24px 30px;
  display: flex;
  align-items: center;
  gap: 20px;
}

.preview-logo {
  width: 56px;
  height: 54px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  border: 2px solid rgba(255, 255, 255, 0.3);
  background: var(--white);
  padding: 2px;
}

.preview-logo img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}

.preview-org {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.8px;
  opacity: 0.8;
  margin-bottom: 4px;
  text-transform: uppercase;
}

.preview-title {
  font-size: 22px;
  font-weight: 700;
  line-height: 1.2;
}

.preview-period {
  font-size: 12.5px;
  opacity: 0.75;
  margin-top: 6px;
}

.preview-body {
  padding: 26px 30px;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 28px;
}

.preview-body .stat-card {
  display: block;
  border: 1.5px solid var(--gray-100);
  border-radius: 9px;
  padding: 20px 16px;
  text-align: center;
  box-shadow: none;
}

.preview-body .stat-card .stat-num {
  font-size: 34px;
  font-weight: 700;
}

.preview-body .stat-num.c-gray {
  color: var(--gray-700);
}

.preview-body .stat-num.c-green {
  color: #16a34a;
}

.preview-body .stat-num.c-blue {
  color: #2563eb;
}

.preview-body .stat-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--gray-500);
  text-transform: uppercase;
  margin-top: 4px;
}

.section-label {
  font-size: 16px;
  font-weight: 700;
  color: var(--maroon);
  margin-bottom: 14px;
  border-bottom: 1.5px solid var(--gray-100);
  padding-bottom: 8px;
}

.chart-wrap {
  max-width: 500px;
  height: 240px;
  margin-top: 2rem;
}

/* ─── Searchable employee picker (Reports → Individual scope) ─── */
.user-search {
  display: flex;
  flex-direction: column;
  gap: 8px;
  position: relative;
}

.user-search-results {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  max-height: 240px;
  overflow-y: auto;
  border: 1px solid var(--gray-200);
  border-radius: 8px;
  background: var(--white);
  box-shadow: var(--shadow-lg);
  z-index: 100;
  display: none;
}

.user-search-results.open {
  display: block;
}

.user-search-item {
  display: flex;
  align-items: center;
  gap: 12px;
  width: 100%;
  padding: 10px 14px;
  background: none;
  border: none;
  border-bottom: 1px solid var(--gray-100);
  text-align: left;
  cursor: pointer;
  transition: var(--transition);
}

.user-search-item:last-child {
  border-bottom: none;
}

.user-search-item:hover {
  background: var(--off-white);
}

.user-search-meta {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.user-search-meta strong {
  color: var(--text);
  font-size: 13.5px;
  font-weight: 600;
}

.user-search-meta .muted {
  color: var(--gray-500);
  font-size: 11.5px;
}

.user-search-picked {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border: 1.5px solid #86efac;
  background: #f0fdf4;
  border-radius: 8px;
  color: #15803d;
  font-size: 13.5px;
  font-weight: 600;
}

.user-search-picked i {
  color: #16a34a;
}

.link-btn {
  margin-left: auto;
  background: none;
  border: none;
  color: var(--maroon);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  text-decoration: underline;
}

/* ─── COMPONENTS: USERS & GROUPS ───────────────────── */

.panels {
  display: grid;
  grid-template-columns: 1fr 480px;
  gap: 24px;
  align-items: start;
}

@media (max-width: 1200px) {
  .panels {
    grid-template-columns: 1fr;
  }
}

.panels .panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18px 22px;
  border-bottom: 1px solid var(--gray-100);
}

.td-name {
  font-weight: 600;
  color: var(--text);
  line-height: 1.4;
}

.td-email {
  color: var(--gray-500);
  font-size: 13px;
}

.group-name {
  font-weight: 700;
  font-size: 14px;
  color: var(--text);
}

.group-sub {
  font-size: 12px;
  color: var(--gray-500);
  margin-top: 2px;
  line-height: 1.4;
}

.action-btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 1.5px solid var(--gray-200);
  background: var(--white);
  color: var(--gray-500);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  cursor: pointer;
  transition: var(--transition);
}

.action-btn:hover {
  border-color: var(--maroon);
  color: var(--maroon);
  background: var(--off-white);
}

.action-btn.deactivate:hover {
  border-color: var(--red-text);
  color: var(--red-text);
}

.action-btn.edit:hover {
  border-color: var(--blue-text);
  color: var(--blue-text);
  background: #eff6ff;
}

.action-btn.delete {
  color: var(--red-text);
}

.action-btn.delete:hover {
  border-color: var(--red-text);
  color: var(--white);
  background: var(--red-text);
}

/* Badge Variants */
.b-active {
  background: var(--green-bg);
  color: var(--green-text);
}

.b-inactive {
  background: #fee2e2;
  color: var(--red-text);
}

/* ─── COMPONENT: OTP MODAL ─────────────────────────── */

.otp-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(20, 0, 0, .55);
  backdrop-filter: blur(2px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 1rem;
  animation: otp-fade-in .18s ease-out;
}

.otp-backdrop.hidden {
  display: none;
}

@keyframes otp-fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.otp-modal {
  background: var(--white);
  border-radius: 14px;
  box-shadow: 0 12px 40px rgba(0, 0, 0, .35);
  width: 100%;
  max-width: 420px;
  padding: 1.75rem 1.75rem 1.5rem;
  text-align: center;
  position: relative;
  animation: otp-pop-in .22s cubic-bezier(.2, .8, .25, 1);
}

@keyframes otp-pop-in {
  from { opacity: 0; transform: translateY(8px) scale(.98); }
  to   { opacity: 1; transform: translateY(0)    scale(1); }
}

.otp-modal-close {
  position: absolute;
  top: 12px;
  right: 14px;
  background: none;
  border: none;
  color: var(--gray-500);
  font-size: 1.1rem;
  cursor: pointer;
  transition: var(--transition);
  padding: 4px 8px;
  border-radius: 6px;
}

.otp-modal-close:hover {
  color: var(--maroon);
  background: var(--gray-100);
}

.otp-modal-icon {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--pale-gold);
  color: var(--maroon);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  margin-bottom: .85rem;
}

.otp-modal h2 {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--maroon);
  margin-bottom: .4rem;
  letter-spacing: .3px;
}

.otp-modal .otp-modal-sub {
  font-size: .82rem;
  color: var(--gray-500);
  margin-bottom: 1.25rem;
  line-height: 1.55;
}

.otp-modal .otp-modal-sub strong {
  color: var(--gray-700);
  font-weight: 600;
}

.otp-input-row {
  display: flex;
  gap: .5rem;
  justify-content: center;
  margin-bottom: .85rem;
}

.otp-input-row input {
  width: 44px;
  height: 52px;
  border: 1.5px solid var(--gray-200);
  border-radius: 10px;
  background: var(--white);
  font-family: inherit;
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--maroon);
  text-align: center;
  outline: none;
  transition: var(--transition);
}

.otp-input-row input:focus {
  border-color: var(--maroon);
  box-shadow: 0 0 0 3px rgba(128, 0, 0, .12);
}

.otp-input-row.is-error input {
  border-color: var(--red-text);
  background: var(--red-bg);
}

.otp-feedback {
  font-size: .78rem;
  min-height: 1.1rem;
  margin-bottom: .8rem;
  line-height: 1.4;
}

.otp-feedback.is-error {
  color: var(--red-text);
}

.otp-feedback.is-success {
  color: var(--green-text);
}

.otp-feedback.is-info {
  color: var(--gray-500);
}

.otp-modal-actions {
  display: flex;
  flex-direction: column;
  gap: .55rem;
}

.otp-modal-actions .btn {
  justify-content: center;
}

.otp-resend {
  font-size: .78rem;
  color: var(--gray-500);
  margin-top: .8rem;
}

.otp-resend button {
  background: none;
  border: none;
  color: var(--maroon);
  font-weight: 600;
  font-family: inherit;
  font-size: inherit;
  cursor: pointer;
  padding: 0;
  text-decoration: none;
  transition: var(--transition);
}

.otp-resend button:disabled {
  color: var(--gray-500);
  cursor: not-allowed;
}

.otp-resend button:not(:disabled):hover {
  color: var(--gold-hover);
  text-decoration: underline;
}

/* Sign-in method segmented control — reuses .auth-toggle base */
.method-toggle {
  margin-top: .25rem;
  margin-bottom: 1.25rem;
}

.method-toggle button .method-icon {
  margin-right: .35rem;
  font-size: .85em;
}

/* ─── PAGE: TERMS & CONDITIONS ─────────────────────── */

.terms-container {
  min-height: 100vh;
  width: 100%;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  background: linear-gradient(135deg, var(--deep-maroon) 0%, var(--maroon) 50%, #a00000 100%);
  padding: 2.5rem 1rem;
}

.terms-box {
  background: var(--white);
  border-radius: 16px;
  box-shadow: 0 8px 40px rgba(0, 0, 0, .35);
  width: 100%;
  max-width: 820px;
  padding: 2.25rem 2.5rem 2.5rem;
  display: flex;
  flex-direction: column;
}

.terms-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding-bottom: 1.25rem;
  border-bottom: 2px solid var(--gold);
  margin-bottom: 1.5rem;
}

.terms-header .terms-logo {
  width: 64px;
  height: 64px;
  object-fit: contain;
  flex-shrink: 0;
}

.terms-header .terms-title-group {
  flex: 1;
  text-align: left;
}

.terms-header h1 {
  font-size: 1.35rem;
  font-weight: 700;
  color: var(--maroon);
  letter-spacing: .3px;
  margin: 0;
}

