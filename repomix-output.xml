<script src="../js/api.js"></script>
<script>
const { apiFetch, requireAuth, setupChrome, fmtDate, fmtHeaderDate, getUser } = PAMS;

let tasks = [];
let users = [];
let groups = [];
let viewingId = null;
let activeStatus = 'ALL';   // which Home-tab status filter is selected

document.addEventListener('DOMContentLoaded', async () => {
  if (!requireAuth()) return;
  setupChrome();
  document.getElementById('headerDate').textContent = fmtHeaderDate();
  wireRibbon();
  await loadAll();
});

// ── Ribbon wiring ────────────────────────────────────────────────────────
// Tabs along the top switch which ribbon panel is visible; the inner
// status-tabs row drives the active filter. Everything triggers renderList()
// so the displayed task set always reflects the current state.
function wireRibbon() {
  // Tab strip
  document.querySelectorAll('.ribbon-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const name = btn.dataset.tab;
      document.querySelectorAll('.ribbon-tab').forEach(t => t.classList.toggle('active', t === btn));
      document.querySelectorAll('.ribbon-panel').forEach(p => p.classList.toggle('active', p.dataset.panel === name));
    });
  });

  // Status sub-tabs (Home panel)
  document.querySelectorAll('.status-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      activeStatus = btn.dataset.status;
      document.querySelectorAll('.status-tab').forEach(t => t.classList.toggle('active', t === btn));
      renderList();
    });
  });

  // Filters / sort / view / admin — anything that changes triggers a re-render
  ['filterPriority','filterGroup','filterAssignee','sortField','sortDir',
   'viewDensity','viewGroupBy','adminSinceDay1','tbSearch']
    .forEach(id => {
      const el = document.getElementById(id);
      if (el) el.addEventListener(el.type === 'search' ? 'input' : 'change', () => {
        if (id === 'adminSinceDay1') loadAll();   // hits API again
        else renderList();
      });
    });
}

async function loadAll() {
  try {
    // Admins can flip "since Day 1" — when on, drop the ?completedSince=today
    // default so the API returns the full completed history.
    const sinceDay1 = document.getElementById('adminSinceDay1')?.checked;
    const qs = sinceDay1 ? '?completedSince=all' : '';

    const [t, u, g] = await Promise.all([
      apiFetch('/tasks' + qs),
      apiFetch('/users'),
      apiFetch('/groups')
    ]);
    tasks  = t.tasks  || [];
    users  = u.users  || [];
    groups = g.groups || [];
    populateAssigneeSelects();
    buildFilterOptions();
    renderList();
    updateOverdueBanner();
  } catch (err) {
    console.error('Load failed:', err);
    document.getElementById('tbRows').innerHTML =
      `<div class="tb-empty">Failed to load tasks: ${err.message}</div>`;
  }
}

function populateAssigneeSelects() {
  // value uses "user:<email>" or "group:<id>" so we can round-trip cleanly
  const userOpts  = users.map(u  => `<option value="user:${u.email}">${u.name || u.email}</option>`).join('');
  const groupOpts = groups.map(g => `<option value="group:${g.id}">${g.name}</option>`).join('');
  const innerHTML = `<option value="">Select assignee</option>
    <optgroup label="Users">${userOpts}</optgroup>
    <optgroup label="Groups">${groupOpts}</optgroup>`;
  document.getElementById('nt-assignee').innerHTML   = innerHTML;
  document.getElementById('edit-assignee').innerHTML = innerHTML;
}

function buildFilterOptions() {
  const groupNames = [...new Set(tasks.filter(t => t.assignee?.type === 'group').map(t => t.assignee.name))].sort();
  const assignees  = [...new Set(tasks.map(t => t.assignee?.name).filter(Boolean))].sort();
  const gEl = document.getElementById('filterGroup'),    gV = gEl.value;
  const aEl = document.getElementById('filterAssignee'), aV = aEl.value;
  gEl.innerHTML = '<option value="">All Groups</option>' + groupNames.map(n => `<option value="${n}">${n}</option>`).join('');
  aEl.innerHTML = '<option value="">All Assignees</option>' + assignees.map(n => `<option value="${n}">${n}</option>`).join('');
  gEl.value = gV; aEl.value = aV;
}

function updateOverdueBanner() {
  const today = new Date(new Date().toDateString());
  const overdue = tasks.filter(t =>
    t.status !== 'COMPLETED' && t.status !== 'CANCELLED' && new Date(t.dueDate) < today
  );
  const banner = document.getElementById('alertBanner');
  if (overdue.length > 0) {
    document.getElementById('alertText').textContent =
      `${overdue.length} task${overdue.length > 1 ? 's are' : ' is'} overdue.`;
    banner.classList.remove('hidden');
  }
}

function prioClass(p)  { return ({URGENT:'p-urgent',HIGH:'p-high',MEDIUM:'p-medium',LOW:'p-low'}[p] || ''); }
function statusClass(s){ return 's-' + (s||'').toLowerCase().replace(/\s+/g,'-'); }
function isOverdue(t)  { return t.status !== 'COMPLETED' && t.status !== 'CANCELLED' && new Date(t.dueDate) < new Date(new Date().toDateString()); }
function esc(s)        { return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

// Build a single full-width row. Shows everything the May-26 spec asked for:
// title + description, assignee/group, priority chip, status chip, due date,
// assigned-by, and quick actions inline on the right.
function buildRow(t) {
  const overdue   = isOverdue(t);
  const assignee  = t.assignee?.name || 'Unassigned';
  const aType     = t.assignee?.type;
  const initials  = t.assignee?.initials || '?';
  const dueLabel  = overdue
    ? `<i class="fa-solid fa-triangle-exclamation" style="color:#b91c1c;"></i> ${fmtDate(t.dueDate)}`
    : fmtDate(t.dueDate);

  return `<div class="tb-row" data-id="${t.id}">
    <div class="tb-row-main" onclick="openView(${t.id})">
      <div class="tb-row-top">
        <span class="tb-title">${esc(t.title)}</span>
        <span class="badge ${prioClass(t.priority)}">${esc(t.priority)}</span>
        <span class="badge ${statusClass(t.status)}">${esc(t.status)}</span>
        ${overdue ? '<span class="tb-flag">OVERDUE</span>' : ''}
      </div>
      ${t.description ? `<div class="tb-desc">${esc(t.description)}</div>` : ''}
      <div class="tb-meta">
        <span class="tb-meta-item">
          <span class="avatar-sm">${esc(initials)}</span>
          ${esc(assignee)} ${aType ? `<span class="tb-meta-faint">(${aType})</span>` : ''}
        </span>
        <span class="tb-meta-item"><i class="fa-regular fa-calendar"></i> Due ${dueLabel}</span>
        <span class="tb-meta-item"><i class="fa-regular fa-user"></i> Assigned by ${esc(t.assignedByName || '—')}</span>
        ${t.createdAt ? `<span class="tb-meta-item"><i class="fa-regular fa-clock"></i> Created ${fmtDate(t.createdAt)}</span>` : ''}
      </div>
    </div>
    <div class="tb-row-actions">
      <button class="ribbon-btn ghost" title="View"   onclick="openView(${t.id})"><i class="fa-regular fa-eye"></i></button>
      <button class="ribbon-btn ghost" title="Edit"   onclick="openEdit(${t.id})"><i class="fa-solid fa-pen"></i></button>
      <button class="ribbon-btn ghost" title="Delete" onclick="openDeleteTask(${t.id})"><i class="fa-solid fa-trash"></i></button>
    </div>
  </div>`;
}

function applyAllFilters() {
  const gF = document.getElementById('filterGroup').value;
  const pF = document.getElementById('filterPriority').value;
  const aF = document.getElementById('filterAssignee').value;
  const q  = (document.getElementById('tbSearch').value || '').trim().toLowerCase();

  let list = tasks.filter(t => {
    if (activeStatus !== 'ALL' && t.status !== activeStatus) return false;
    if (pF && t.priority !== pF) return false;
    if (gF && !(t.assignee?.type === 'group' && t.assignee.name === gF)) return false;
    if (aF && t.assignee?.name !== aF) return false;
    if (q && !(t.title.toLowerCase().includes(q) || (t.description||'').toLowerCase().includes(q))) return false;
    return true;
  });

  const field = document.getElementById('sortField').value;
  const dir   = document.getElementById('sortDir').value === 'desc' ? -1 : 1;
  const prioRank = { URGENT: 0, HIGH: 1, MEDIUM: 2, LOW: 3 };
  list.sort((a, b) => {
    let av, bv;
    switch (field) {
      case 'priority': av = prioRank[a.priority] ?? 99; bv = prioRank[b.priority] ?? 99; break;
      case 'created':  av = new Date(a.createdAt || 0); bv = new Date(b.createdAt || 0); break;
      case 'title':    av = (a.title||'').toLowerCase(); bv = (b.title||'').toLowerCase(); break;
      case 'due':
      default:         av = new Date(a.dueDate || 0); bv = new Date(b.dueDate || 0);
    }
    return av < bv ? -1 * dir : av > bv ? 1 * dir : 0;
  });
  return list;
}

function renderList() {
  // Refresh counters across all status tabs (even ones not currently shown)
  const allTotals = { ALL: tasks.length, PENDING: 0, 'IN PROGRESS': 0, COMPLETED: 0, CANCELLED: 0 };
  tasks.forEach(t => { if (allTotals[t.status] != null) allTotals[t.status]++; });
  document.querySelectorAll('.status-tab .cnt').forEach(el => {
    const key = el.dataset.cnt;
    el.textContent = allTotals[key] ?? 0;
  });

  const list  = applyAllFilters();
  const rows  = document.getElementById('tbRows');
  const label = document.getElementById('tbResultsLabel');
  const density = document.getElementById('viewDensity').value;
  const groupBy = document.getElementById('viewGroupBy').value;

  rows.className = 'tb-rows ' + (density === 'compact' ? 'is-compact' : '');

  if (list.length === 0) {
    rows.innerHTML = `<div class="tb-empty">No tasks match the current filters.</div>`;
    label.textContent = '0 tasks';
    return;
  }

  if (groupBy) {
    const groups = list.reduce((acc, t) => {
      const k = groupBy === 'status'   ? t.status
              : groupBy === 'priority' ? t.priority
              :                          (t.assignee?.type === 'group' ? t.assignee.name : '— No group —');
      (acc[k] = acc[k] || []).push(t);
      return acc;
    }, {});
    rows.innerHTML = Object.entries(groups).map(([k, items]) => `
      <div class="tb-group-label">${esc(k)} <span class="tb-group-count">${items.length}</span></div>
      ${items.map(buildRow).join('')}`).join('');
  } else {
    rows.innerHTML = list.map(buildRow).join('');
  }
  label.textContent = `${list.length} task${list.length === 1 ? '' : 's'}`
    + (activeStatus !== 'ALL' ? ` · ${activeStatus}` : '');
}

function clearFilters() {
  ['filterGroup','filterPriority','filterAssignee','tbSearch'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  renderList();
}

// Export the currently-visible task set as a CSV download (admin-only).
function exportVisibleTasks() {
  const list = applyAllFilters();
  const header = ['Title','Description','Priority','Status','Due','Assignee','Type','Assigned by','Created'];
  const rows = list.map(t => [
    t.title, t.description || '', t.priority, t.status,
    (t.dueDate || '').slice(0,10),
    t.assignee?.name || '', t.assignee?.type || '',
    t.assignedByName || '',
    (t.createdAt || '').slice(0,10)
  ]);
  const csv = [header, ...rows]
    .map(r => r.map(c => `"${String(c).replace(/"/g, '""')}"`).join(','))
    .join('\n');
  const blob = new Blob([csv], { type: 'text/csv' });
  const url  = URL.createObjectURL(blob);
  const a    = Object.assign(document.createElement('a'), {
    href: url, download: `pams-tasks-${new Date().toISOString().slice(0,10)}.csv`
  });
  document.body.appendChild(a); a.click(); a.remove();
  URL.revokeObjectURL(url);
}

// ─── NEW TASK ──────────────────────────────────────────────────────
function openNewTask() {
  ['nt-title','nt-desc','nt-priority','nt-due','nt-assignee'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('newTaskModal').classList.add('open');
}

async function createTask() {
  const title       = document.getElementById('nt-title').value.trim();
  const description = document.getElementById('nt-desc').value.trim();
  const priority    = document.getElementById('nt-priority').value;
  const dueDate     = document.getElementById('nt-due').value;
  const aVal        = document.getElementById('nt-assignee').value;

  if (!title)    { alert('Please enter a task title.'); return; }
  if (!priority) { alert('Please select a priority.');  return; }
  if (!dueDate)  { alert('Please select a due date.');  return; }
  if (!aVal)     { alert('Please select an assignee.'); return; }

  const me = getUser();
  const [type, key] = aVal.split(':');
  const body = {
    title, description, priority, status: 'PENDING', dueDate,
    assignedByEmail: me.email,
    ...(type === 'user' ? { assigneeEmail: key } : { groupId: parseInt(key) })
  };

  try {
    await apiFetch('/tasks', 'POST', body);
    document.getElementById('newTaskModal').classList.remove('open');
    await loadAll();
  } catch (err) {
    alert('Failed to create task: ' + err.message);
  }
}

// ─── VIEW ──────────────────────────────────────────────────────────
function openView(id) {
  const t = tasks.find(x => x.id === id);
  if (!t) return;
  viewingId = id;
  document.getElementById('view-title').textContent    = t.title;
  document.getElementById('view-desc').textContent     = t.description || '—';
  document.getElementById('view-status').textContent   = t.status;
  document.getElementById('view-priority').textContent = t.priority;
  document.getElementById('view-assignee').textContent = t.assignee?.name || 'Unassigned';
  document.getElementById('view-due').textContent      = fmtDate(t.dueDate);
  document.getElementById('viewModal').classList.add('open');
}
function openEditFromView()   { document.getElementById('viewModal').classList.remove('open'); openEdit(viewingId); }
function openDeleteFromView() { document.getElementById('viewModal').classList.remove('open'); openDeleteTask(viewingId); }

// ─── EDIT ──────────────────────────────────────────────────────────
function openEdit(id) {
  const t = tasks.find(x => x.id === id);
  if (!t) return;
  document.getElementById('edit-id').value       = id;
  document.getElementById('edit-title').value    = t.title;
  document.getElementById('edit-desc').value     = t.description || '';
  document.getElementById('edit-status').value   = t.status;
  document.getElementById('edit-priority').value = t.priority;
  document.getElementById('edit-assignee').value =
    t.assignee?.type === 'user'  ? `user:${t.assignee.email}` :
    t.assignee?.type === 'group' ? `group:${t.assignee.id}`   : '';
  document.getElementById('edit-due').value      = (t.dueDate || '').slice(0, 10);
  document.getElementById('editModal').classList.add('open');
}

async function saveEdit() {
  const id          = parseInt(document.getElementById('edit-id').value);
  const title       = document.getElementById('edit-title').value.trim();
  const description = document.getElementById('edit-desc').value.trim();
  const status      = document.getElementById('edit-status').value;
  const priority    = document.getElementById('edit-priority').value;
  const dueDate     = document.getElementById('edit-due').value;
  const aVal        = document.getElementById('edit-assignee').value;

  const body = { title, description, status, priority, dueDate };
  if (aVal) {
    const [type, key] = aVal.split(':');
    if (type === 'user')  body.assigneeEmail = key;
    if (type === 'group') body.groupId       = parseInt(key);
  }

  try {
    await apiFetch(`/tasks/${id}`, 'PUT', body);
    document.getElementById('editModal').classList.remove('open');
    await loadAll();
  } catch (err) {
    alert('Failed to update task: ' + err.message);
  }
}

// ─── DELETE ────────────────────────────────────────────────────────
function openDeleteTask(id) {
  viewingId = id;
  document.getElementById('delete-name').textContent = tasks.find(x => x.id === id)?.title || '';
  document.getElementById('deleteModal').classList.add('open');
}

async function doDelete() {
  try {
    await apiFetch(`/tasks/${viewingId}`, 'DELETE');
    document.getElementById('deleteModal').classList.remove('open');
    await loadAll();
  } catch (err) {
    alert('Failed to delete task: ' + err.message);
  }
}
</script>
</body>
</html>
</file>

