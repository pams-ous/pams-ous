<!-- Generate Report Modal -->
<div class="modal-overlay hidden" id="modal-gen-report">
  <div class="modal">
    <div class="modal-header">
      <h3><i class="fas fa-file-alt"></i> Generate Report</h3>
      <button class="modal-close" onclick="closeModal('modal-gen-report')">&times;</button>
    </div>
    <div class="modal-body">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem">
        <div class="form-group"><label class="form-label">Report Type</label>
          <select id="rp-type" class="form-control">
            <option value="daily">Daily</option><option value="weekly">Weekly</option><option value="annual">Annual</option>
          </select></div>
        <div class="form-group"><label class="form-label">Scope</label>
          <select id="rp-scope" class="form-control">
            <option value="all">All</option><option value="group">Group</option><option value="individual">Individual</option>
          </select></div>
        <div class="form-group"><label class="form-label">Period Start</label>
          <input id="rp-start" type="date" class="form-control" value="2026-04-21"></div>
        <div class="form-group"><label class="form-label">Period End</label>
          <input id="rp-end" type="date" class="form-control" value="2026-04-27"></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-gen-report')">Cancel</button>
      <button class="btn btn-primary" onclick="generateReport()"><i class="fas fa-cog"></i> Generate</button>
    </div>
  </div>
</div>

<!-- Add User Modal -->
<div class="modal-overlay hidden" id="modal-add-user">
  <div class="modal">
    <div class="modal-header">
      <h3><i class="fas fa-user-plus"></i> Add New User</h3>
      <button class="modal-close" onclick="closeModal('modal-add-user')">&times;</button>
    </div>
    <div class="modal-body">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem">
        <div class="form-group"><label class="form-label">First Name</label>
          <input id="nu-first" class="form-control" placeholder="First name"></div>
        <div class="form-group"><label class="form-label">Last Name</label>
          <input id="nu-last" class="form-control" placeholder="Last name"></div>
      </div>
      <div class="form-group mt-3"><label class="form-label">Email</label>
        <input id="nu-email" type="email" class="form-control" placeholder="name@pup.edu.ph"></div>
      <div class="form-group mt-3"><label class="form-label">Role</label>
        <select id="nu-role" class="form-control"><option value="member">Member</option><option value="admin">Admin</option></select></div>
      <div class="form-group mt-3"><label class="form-label">Assign to Group</label>
        <select id="nu-group" class="form-control"><option value="">— None —</option></select></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-add-user')">Cancel</button>
      <button class="btn btn-primary" onclick="addUser()"><i class="fas fa-save"></i> Save User</button>
    </div>
  </div>
</div>

<!-- Add Group Modal -->
<div class="modal-overlay hidden" id="modal-add-group">
  <div class="modal">
    <div class="modal-header">
      <h3><i class="fas fa-layer-group"></i> Add New Group</h3>
      <button class="modal-close" onclick="closeModal('modal-add-group')">&times;</button>
    </div>
    <div class="modal-body">
      <div class="form-group"><label class="form-label">Group Name</label>
        <input id="ng-name" class="form-control" placeholder="e.g. Group 4"></div>
      <div class="form-group mt-3"><label class="form-label">Description</label>
        <textarea id="ng-desc" class="form-control" placeholder="Optional description..."></textarea></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-add-group')">Cancel</button>
      <button class="btn btn-primary" onclick="addGroup()"><i class="fas fa-save"></i> Save Group</button>
    </div>
  </div>
</div>

