     MODALS
════════════════════════════════════════════════════ -->

<!-- Add Task Modal -->
<div class="modal-overlay hidden" id="modal-add-task">
  <div class="modal">
    <div class="modal-header">
      <h3><i class="fas fa-plus-circle"></i> Create New Task</h3>
      <button class="modal-close" onclick="closeModal('modal-add-task')">&times;</button>
    </div>
    <div class="modal-body">
      <div class="form-group"><label class="form-label">Task Title *</label>
        <input id="t-title" class="form-control" placeholder="Enter task title"></div>
      <div class="form-group mt-3"><label class="form-label">Description</label>
        <textarea id="t-desc" class="form-control" placeholder="Describe the task..."></textarea></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-top:.75rem">
        <div class="form-group"><label class="form-label">Priority</label>
          <select id="t-priority" class="form-control">
            <option value="low">Low</option><option value="medium" selected>Medium</option>
            <option value="high">High</option><option value="urgent">Urgent</option>
          </select></div>
        <div class="form-group"><label class="form-label">Due Date</label>
          <input id="t-due" type="date" class="form-control"></div>
        <div class="form-group"><label class="form-label">Assign to User</label>
          <select id="t-user" class="form-control"><option value="">— Select —</option></select></div>
        <div class="form-group"><label class="form-label">Assign to Group</label>
          <select id="t-group" class="form-control"><option value="">— Select —</option></select></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-add-task')">Cancel</button>
      <button class="btn btn-primary" onclick="addTask()"><i class="fas fa-save"></i> Create Task</button>
    </div>
  </div>
</div>

<!-- Task Detail Modal -->
<div class="modal-overlay hidden" id="modal-task-detail">
  <div class="modal" style="max-width:680px">
    <div class="modal-header">
      <h3 id="td-title"><i class="fas fa-info-circle"></i> Task Detail</h3>
      <button class="modal-close" onclick="closeModal('modal-task-detail')">&times;</button>
    </div>
    <div class="modal-body">
      <div class="task-detail-grid">
        <div class="form-group"><label class="form-label">Status</label><div id="td-status"></div></div>
        <div class="form-group"><label class="form-label">Priority</label><div id="td-priority"></div></div>
        <div class="form-group"><label class="form-label">Assigned To</label><div id="td-assigned" style="font-size:.875rem"></div></div>
        <div class="form-group"><label class="form-label">Due Date</label><div id="td-due" style="font-size:.875rem"></div></div>
      </div>
      <div class="form-group">
        <label class="form-label">Description</label>
        <p id="td-desc" style="font-size:.875rem;color:var(--gray-700);padding:.5rem 0"></p>
      </div>
      <div style="margin-top:1rem">
        <div class="card-header" style="border:none;padding:0;margin-bottom:.5rem">
          <span class="card-title">Update History</span>
          <button class="btn btn-primary btn-sm" onclick="showLogUpdateFor(currentTaskId)"><i class="fas fa-pen"></i> Log</button>
        </div>
        <div class="update-log" id="td-updates"></div>
      </div>
    </div>
  </div>
</div>

<!-- Log Update Modal -->
<div class="modal-overlay hidden" id="modal-log-update">
  <div class="modal">
    <div class="modal-header">
      <h3><i class="fas fa-pen"></i> Log Accomplishment</h3>
      <button class="modal-close" onclick="closeModal('modal-log-update')">&times;</button>
    </div>
    <div class="modal-body">
