<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Portal – PUP OUS - PAMS</title>
    <link rel="stylesheet" href="../css/style.css">
    <link rel="icon" type="image/webp" href="../assets/pup_ous_seal.webp">
</head>

<body class="login-container">
    <div class="login-box">
        <a href="../index.html" class="color-maroon fw-600 d-block mb-4 back-link no-underline">
            <i class="fas fa-arrow-left"></i> Back to Selection
        </a>
        <img src="../assets/pup_ous_seal.webp" alt="PUP Logo" class="login-logo">
        <h1 class="color-maroon fw-700 text-sm mt-1">ADMINISTRATOR ACCESS</h1>
        <p class="color-gray text-xs mb-4">Secure Portal for System Management</p>

        <div class="auth-toggle mt-4" role="tablist" aria-label="Admin authentication">
            <button id="showAdminLogin" class="active" role="tab" aria-selected="true">Sign In</button>
            <button id="showAdminSignup" role="tab" aria-selected="false">Sign Up</button>
        </div>

        <!-- Admin Login Form -->
        <form class="mt-4" id="adminLoginForm" aria-label="Administrator Login Form" data-auth-mode="password">
            <div class="auth-toggle method-toggle" role="tablist" aria-label="Choose sign-in method">
                <button type="button" data-method="password" class="active" role="tab" aria-selected="true">
                    <i class="fa-solid fa-key method-icon" aria-hidden="true"></i>Security Key
                </button>
                <button type="button" data-method="otp" role="tab" aria-selected="false">
                    <i class="fa-solid fa-envelope method-icon" aria-hidden="true"></i>Email OTP
                </button>
            </div>

            <div class="form-group">
                <label class="form-label" for="admin-email">Admin Email</label>
                <input type="email" id="admin-email" name="email" class="form-control" placeholder="admin@pup.edu.ph"
                    required aria-required="true">
            </div>
            <div class="form-group" data-method-only="password">
                <label class="form-label" for="admin-key">Security Key</label>
                <div class="password-field-wrap">
                    <input type="password" id="admin-key" name="password" class="form-control" placeholder="••••••••"
                        required aria-required="true">
                    <button type="button" class="pass-toggle" onclick="togglePasswordVisibility('admin-key', this)"
                        aria-label="Toggle password visibility">
                        <i class="fa-regular fa-eye-slash"></i>
                    </button>
                </div>
            </div>
            <button type="submit" class="btn btn-primary w-full mt-2" aria-label="Authorize and Login" data-submit-label>
                <i class="fas fa-lock" aria-hidden="true"></i> Authorize Access
            </button>
            <p class="terms-agreement">
                By signing in, you agree to our
                <a href="../pages/terms-and-conditions.html"
                    aria-label="Read the PAMS Terms and Conditions">Terms and Conditions</a>.
            </p>
            <div class="mt-3 text-xs text-center" data-method-only="password">
                <a href="forgot-password.html" class="color-maroon fw-600 no-underline">Forgot your password?</a>
            </div>
            <div class="mt-3 text-xs color-gray text-center">
                <i class="fas fa-info-circle" aria-hidden="true"></i>
                This portal is for pre-provisioned administrative accounts only.
            </div>
        </form>

        <!-- Admin Signup Form (Initially Hidden) -->
        <form id="adminSignupForm" class="mt-4 hidden" aria-label="Administrator Registration Form">
            <div class="form-group">
                <label class="form-label" for="admin-signup-emp-code">Employee Code</label>
                <input type="text" id="admin-signup-emp-code" name="employeeCode" class="form-control"
                    placeholder="PUP-202X-XXXX" autocomplete="off">
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label" for="admin-signup-last-name">Last Name *</label>
                    <input type="text" id="admin-signup-last-name" name="lastName" class="form-control"
                        placeholder="Dela Cruz" required aria-required="true">
                </div>
                <div class="form-group">
                    <label class="form-label" for="admin-signup-first-name">First Name *</label>
                    <input type="text" id="admin-signup-first-name" name="firstName" class="form-control"
                        placeholder="Juan" required aria-required="true">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label" for="admin-signup-middle-name">Middle Name</label>
                    <input type="text" id="admin-signup-middle-name" name="middleName" class="form-control">
                </div>
                <div class="form-group flex-80">
                    <label class="form-label" for="admin-signup-suffix">Suffix</label>
                    <input type="text" id="admin-signup-suffix" name="suffix" class="form-control" placeholder="Jr.">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="admin-signup-email">Admin Email *</label>
                <input type="email" id="admin-signup-email" name="email" class="form-control"
                    placeholder="admin@pup.edu.ph" required aria-required="true">
            </div>

            <div class="form-group">
                <label class="form-label" for="admin-signup-password">Password *</label>
                <div class="password-field-wrap">
                    <input type="password" id="admin-signup-password" name="password" class="form-control"
                        placeholder="••••••••" required aria-required="true">
                    <button type="button" class="pass-toggle"
                        onclick="togglePasswordVisibility('admin-signup-password', this)"
                        aria-label="Toggle password visibility">
                        <i class="fa-regular fa-eye-slash"></i>
                    </button>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="admin-signup-confirm-password">Confirm Password *</label>
                <div class="password-field-wrap">
                    <input type="password" id="admin-signup-confirm-password" name="confirmPassword" class="form-control"
                        placeholder="••••••••" required aria-required="true">
                    <button type="button" class="pass-toggle"
