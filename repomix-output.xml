-- and the seed rows. Safe to re-run: DROP TABLE IF EXISTS guards each table.
--
-- Loads from PowerShell:    mysql -u root -p < .\sql\schema.sql
-- Or in MySQL Workbench:    File -> Open SQL Script -> Execute All

CREATE DATABASE IF NOT EXISTS `people`
    CHARACTER SET utf8mb4
    COLLATE utf8mb4_0900_ai_ci;

USE `people`;

