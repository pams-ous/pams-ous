  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    :root {
      --maroon:       #800000;
      --dark-maroon:  #5a0000;
      --deep-maroon:  #3d0000;
      --gold:         #DAA520;
      --light-gold:   #FFD700;
      --pale-gold:    #fff3cd;
      --white:        #ffffff;
      --off-white:    #f8f4f4;
      --gray-100:     #f4f4f4;
      --gray-200:     #e9ecef;
      --gray-500:     #6c757d;
      --gray-700:     #495057;
      --text:         #2d2d2d;
      --sidebar-w:    260px;
      --header-h:     64px;
      --radius:       10px;
      --shadow:       0 2px 12px rgba(0,0,0,.10);
      --shadow-lg:    0 4px 24px rgba(0,0,0,.15);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Poppins', sans-serif;
      background: var(--off-white);
      color: var(--text);
      min-height: 100vh;
    }

    /* ─── UTILITY ─────────────────────────────────────── */
    .hidden { display: none !important; }
    .flex { display: flex; }
    .flex-col { flex-direction: column; }
    .items-center { align-items: center; }
    .gap-2 { gap: .5rem; }
    .gap-3 { gap: .75rem; }
    .gap-4 { gap: 1rem; }
    .mt-1 { margin-top: .25rem; }
    .mt-2 { margin-top: .5rem; }
    .mt-3 { margin-top: .75rem; }
    .mt-4 { margin-top: 1rem; }
    .w-full { width: 100%; }
    .text-sm { font-size: .85rem; }
    .text-xs { font-size: .75rem; }
    .fw-600 { font-weight: 600; }
    .color-maroon { color: var(--maroon); }
    .color-gold { color: var(--gold); }
    .color-gray { color: var(--gray-500); }

    /* ─── BADGES ──────────────────────────────────────── */
    .badge {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 20px;
      font-size: .72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .4px;
    }
    .badge-pending    { background:#fff3cd; color:#856404; }
    .badge-in_progress{ background:#cce5ff; color:#004085; }
    .badge-completed  { background:#d4edda; color:#155724; }
    .badge-cancelled  { background:#f8d7da; color:#721c24; }
    .badge-low        { background:#e2e3e5; color:#383d41; }
    .badge-medium     { background:#cce5ff; color:#004085; }
    .badge-high       { background:#fff3cd; color:#856404; }
    .badge-urgent     { background:#f8d7da; color:#721c24; }
    .badge-admin      { background:var(--pale-gold); color:var(--dark-maroon); }
    .badge-member     { background:#e2e3e5; color:#383d41; }
    .badge-leader     { background:var(--pale-gold); color:var(--dark-maroon); }

    /* ─── BUTTONS ─────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      padding: .5rem 1.1rem;
      border: none;
      border-radius: var(--radius);
      font-family: inherit;
      font-size: .875rem;
      font-weight: 500;
      cursor: pointer;
      transition: all .15s ease;
    }
    .btn-primary { background: var(--maroon); color: var(--white); }
    .btn-primary:hover { background: var(--dark-maroon); }
    .btn-gold { background: var(--gold); color: var(--white); }
    .btn-gold:hover { background: #b8860b; }
    .btn-outline {
      background: transparent;
      color: var(--maroon);
      border: 1.5px solid var(--maroon);
    }
    .btn-outline:hover { background: var(--maroon); color: var(--white); }
    .btn-sm { padding: .3rem .8rem; font-size: .78rem; }
    .btn-danger { background: #dc3545; color: #fff; }
    .btn-danger:hover { background: #c82333; }
    .btn-ghost {
      background: transparent;
      color: var(--gray-500);
      border: 1.5px solid var(--gray-200);
    }
    .btn-ghost:hover { background: var(--gray-100); }

    /* ─── CARD ────────────────────────────────────────── */
    .card {
      background: var(--white);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 1.25rem;
    }
    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
      padding-bottom: .75rem;
      border-bottom: 2px solid var(--off-white);
    }
    .card-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--maroon);
    }

    /* ─── FORM ELEMENTS ───────────────────────────────── */
    .form-group { display: flex; flex-direction: column; gap: .3rem; }
    .form-label { font-size: .82rem; font-weight: 500; color: var(--gray-700); }
    .form-control {
      padding: .55rem .85rem;
      border: 1.5px solid var(--gray-200);
      border-radius: 8px;
      font-family: inherit;
      font-size: .875rem;
      color: var(--text);
      background: var(--white);
      transition: border-color .15s ease;
      outline: none;
    }
    .form-control:focus { border-color: var(--maroon); }
    select.form-control { cursor: pointer; }
    textarea.form-control { resize: vertical; min-height: 80px; }

    /* ─── TABLE ───────────────────────────────────────── */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead tr { background: var(--maroon); color: var(--white); }
    thead th { padding: .75rem 1rem; text-align: left; font-size: .82rem; font-weight: 500; }
    tbody tr { border-bottom: 1px solid var(--gray-200); }
    tbody tr:hover { background: var(--off-white); }
    tbody td { padding: .7rem 1rem; font-size: .875rem; }

    /* ─── MODAL ───────────────────────────────────────── */
    .modal-overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,.45);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .modal {
      background: var(--white);
      border-radius: var(--radius);
      box-shadow: var(--shadow-lg);
      width: 100%;
      max-width: 560px;
      max-height: 90vh;
      overflow-y: auto;
    }
    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.1rem 1.5rem;
      background: var(--maroon);
      color: var(--white);
      border-radius: var(--radius) var(--radius) 0 0;
    }
    .modal-header h3 { font-size: 1rem; font-weight: 600; }
    .modal-close {
      background: none; border: none; color: var(--white);
      font-size: 1.2rem; cursor: pointer; opacity: .8;
    }
    .modal-close:hover { opacity: 1; }
    .modal-body { padding: 1.5rem; }
    .modal-footer {
      display: flex; gap: .75rem; justify-content: flex-end;
      padding: 1rem 1.5rem;
      border-top: 1px solid var(--gray-200);
    }

    /* ═══════════════════════════════════════════════════
       LOGIN PAGE
    ═══════════════════════════════════════════════════ */
    #login-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, var(--deep-maroon) 0%, var(--maroon) 50%, #a00000 100%);
      padding: 1rem;
    }
    .login-box {
      background: var(--white);
      border-radius: 16px;
      box-shadow: 0 8px 40px rgba(0,0,0,.35);
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 420px;
      text-align: center;
    }
    .login-logo {
      width: 90px;
      height: 90px;
      object-fit: contain;
      margin-bottom: .75rem;
    }
    .login-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--maroon);
      line-height: 1.3;
      margin-bottom: .2rem;
    }
    .login-subtitle {
      font-size: .78rem;
      color: var(--gray-500);
      margin-bottom: 1.75rem;
    }
    .login-form { text-align: left; }
    .login-btn {
      width: 100%;
      padding: .75rem;
      background: var(--maroon);
      color: var(--white);
      border: none;
      border-radius: var(--radius);
      font-family: inherit;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: .75rem;
      transition: background .15s ease;
    }
    .login-btn:hover { background: var(--dark-maroon); }
    .login-hint {
      margin-top: 1.25rem;
      padding: .75rem;
      background: var(--off-white);
      border-radius: 8px;
      font-size: .75rem;
      color: var(--gray-500);
      text-align: left;
    }
    .login-hint strong { color: var(--maroon); }
    .login-divider {
      display: flex;
      align-items: center;
      gap: .75rem;
      color: var(--gray-500);
      font-size: .78rem;
      margin: 1rem 0;
    }
    .login-divider::before, .login-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--gray-200);
    }

    /* ═══════════════════════════════════════════════════
       MAIN APP LAYOUT
    ═══════════════════════════════════════════════════ */
    #app {
      display: flex;
      min-height: 100vh;
    }

    /* ─── SIDEBAR ─────────────────────────────────────── */
    #sidebar {
      width: var(--sidebar-w);
      min-height: 100vh;
      background: linear-gradient(180deg, var(--deep-maroon) 0%, var(--dark-maroon) 100%);
      color: var(--white);
      display: flex;
