<file path="frontend/mockup/mockindex.html">
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PUP OUS – Personnel Daily Accomplishment Report System</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    :root {
      --maroon:       #800000;
      --dark-maroon:  #5a0000;
      --deep-maroon:  #3d0000;
      --gold:         #DAA520;
      --light-gold:   #FFD700;
      --pale-gold:    #fff3cd;
      --white:        #ffffff;
      --off-white:    #f8f4f4;
      --gray-100:     #f4f4f4;
      --gray-200:     #e9ecef;
      --gray-500:     #6c757d;
      --gray-700:     #495057;
      --text:         #2d2d2d;
      --sidebar-w:    260px;
      --header-h:     64px;
      --radius:       10px;
      --shadow:       0 2px 12px rgba(0,0,0,.10);
      --shadow-lg:    0 4px 24px rgba(0,0,0,.15);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Poppins', sans-serif;
      background: var(--off-white);
      color: var(--text);
      min-height: 100vh;
    }

    /* ─── UTILITY ─────────────────────────────────────── */
    .hidden { display: none !important; }
    .flex { display: flex; }
    .flex-col { flex-direction: column; }
    .items-center { align-items: center; }
    .gap-2 { gap: .5rem; }
    .gap-3 { gap: .75rem; }
    .gap-4 { gap: 1rem; }
    .mt-1 { margin-top: .25rem; }
    .mt-2 { margin-top: .5rem; }
    .mt-3 { margin-top: .75rem; }
    .mt-4 { margin-top: 1rem; }
    .w-full { width: 100%; }
    .text-sm { font-size: .85rem; }
    .text-xs { font-size: .75rem; }
    .fw-600 { font-weight: 600; }
    .color-maroon { color: var(--maroon); }
    .color-gold { color: var(--gold); }
    .color-gray { color: var(--gray-500); }

    /* ─── BADGES ──────────────────────────────────────── */
    .badge {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 20px;
      font-size: .72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .4px;
    }
    .badge-pending    { background:#fff3cd; color:#856404; }
    .badge-in_progress{ background:#cce5ff; color:#004085; }
    .badge-completed  { background:#d4edda; color:#155724; }
    .badge-cancelled  { background:#f8d7da; color:#721c24; }
    .badge-low        { background:#e2e3e5; color:#383d41; }
    .badge-medium     { background:#cce5ff; color:#004085; }
    .badge-high       { background:#fff3cd; color:#856404; }
    .badge-urgent     { background:#f8d7da; color:#721c24; }
    .badge-admin      { background:var(--pale-gold); color:var(--dark-maroon); }
    .badge-member     { background:#e2e3e5; color:#383d41; }
    .badge-leader     { background:var(--pale-gold); color:var(--dark-maroon); }

    /* ─── BUTTONS ─────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      padding: .5rem 1.1rem;
      border: none;
      border-radius: var(--radius);
      font-family: inherit;
      font-size: .875rem;
      font-weight: 500;
      cursor: pointer;
      transition: all .15s ease;
    }
    .btn-primary { background: var(--maroon); color: var(--white); }
    .btn-primary:hover { background: var(--dark-maroon); }
    .btn-gold { background: var(--gold); color: var(--white); }
    .btn-gold:hover { background: #b8860b; }
    .btn-outline {
      background: transparent;
      color: var(--maroon);
      border: 1.5px solid var(--maroon);
    }
    .btn-outline:hover { background: var(--maroon); color: var(--white); }
    .btn-sm { padding: .3rem .8rem; font-size: .78rem; }
    .btn-danger { background: #dc3545; color: #fff; }
    .btn-danger:hover { background: #c82333; }
    .btn-ghost {
      background: transparent;
      color: var(--gray-500);
      border: 1.5px solid var(--gray-200);
    }
    .btn-ghost:hover { background: var(--gray-100); }

    /* ─── CARD ────────────────────────────────────────── */
    .card {
      background: var(--white);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 1.25rem;
    }
    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
      padding-bottom: .75rem;
      border-bottom: 2px solid var(--off-white);
    }
    .card-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--maroon);
    }

    /* ─── FORM ELEMENTS ───────────────────────────────── */
    .form-group { display: flex; flex-direction: column; gap: .3rem; }
    .form-label { font-size: .82rem; font-weight: 500; color: var(--gray-700); }
    .form-control {
      padding: .55rem .85rem;
      border: 1.5px solid var(--gray-200);
      border-radius: 8px;
      font-family: inherit;
      font-size: .875rem;
      color: var(--text);
      background: var(--white);
      transition: border-color .15s ease;
      outline: none;
    }
    .form-control:focus { border-color: var(--maroon); }
    select.form-control { cursor: pointer; }
    textarea.form-control { resize: vertical; min-height: 80px; }

    /* ─── TABLE ───────────────────────────────────────── */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead tr { background: var(--maroon); color: var(--white); }
    thead th { padding: .75rem 1rem; text-align: left; font-size: .82rem; font-weight: 500; }
    tbody tr { border-bottom: 1px solid var(--gray-200); }
    tbody tr:hover { background: var(--off-white); }
    tbody td { padding: .7rem 1rem; font-size: .875rem; }

    /* ─── MODAL ───────────────────────────────────────── */
    .modal-overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,.45);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .modal {
      background: var(--white);
      border-radius: var(--radius);
      box-shadow: var(--shadow-lg);
      width: 100%;
      max-width: 560px;
      max-height: 90vh;
      overflow-y: auto;
    }
    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.1rem 1.5rem;
      background: var(--maroon);
      color: var(--white);
      border-radius: var(--radius) var(--radius) 0 0;
    }
    .modal-header h3 { font-size: 1rem; font-weight: 600; }
    .modal-close {
      background: none; border: none; color: var(--white);
      font-size: 1.2rem; cursor: pointer; opacity: .8;
    }
    .modal-close:hover { opacity: 1; }
    .modal-body { padding: 1.5rem; }
    .modal-footer {
      display: flex; gap: .75rem; justify-content: flex-end;
      padding: 1rem 1.5rem;
      border-top: 1px solid var(--gray-200);
    }

    /* ═══════════════════════════════════════════════════
       LOGIN PAGE
    ═══════════════════════════════════════════════════ */
    #login-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, var(--deep-maroon) 0%, var(--maroon) 50%, #a00000 100%);
      padding: 1rem;
    }
    .login-box {
      background: var(--white);
      border-radius: 16px;
      box-shadow: 0 8px 40px rgba(0,0,0,.35);
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 420px;
      text-align: center;
    }
    .login-logo {
      width: 90px;
      height: 90px;
      object-fit: contain;
      margin-bottom: .75rem;
    }
    .login-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--maroon);
      line-height: 1.3;
      margin-bottom: .2rem;
    }
    .login-subtitle {
      font-size: .78rem;
      color: var(--gray-500);
      margin-bottom: 1.75rem;
    }
    .login-form { text-align: left; }
    .login-btn {
      width: 100%;
      padding: .75rem;
      background: var(--maroon);
      color: var(--white);
      border: none;
      border-radius: var(--radius);
      font-family: inherit;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: .75rem;
      transition: background .15s ease;
    }
    .login-btn:hover { background: var(--dark-maroon); }
    .login-hint {
      margin-top: 1.25rem;
      padding: .75rem;
      background: var(--off-white);
      border-radius: 8px;
      font-size: .75rem;
      color: var(--gray-500);
      text-align: left;
    }
    .login-hint strong { color: var(--maroon); }
    .login-divider {
      display: flex;
      align-items: center;
      gap: .75rem;
      color: var(--gray-500);
      font-size: .78rem;
      margin: 1rem 0;
    }
    .login-divider::before, .login-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--gray-200);
    }

    /* ═══════════════════════════════════════════════════
       MAIN APP LAYOUT
    ═══════════════════════════════════════════════════ */
    #app {
      display: flex;
      min-height: 100vh;
    }

    /* ─── SIDEBAR ─────────────────────────────────────── */
    #sidebar {
      width: var(--sidebar-w);
      min-height: 100vh;
      background: linear-gradient(180deg, var(--deep-maroon) 0%, var(--dark-maroon) 100%);
      color: var(--white);
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0;
      z-index: 100;
      box-shadow: 4px 0 20px rgba(0,0,0,.2);
    }
    .sidebar-brand {
      display: flex;
      align-items: center;
      gap: .75rem;
      padding: 1.25rem 1rem;
      border-bottom: 1px solid rgba(255,255,255,.1);
    }
    .sidebar-brand img { width: 42px; height: 42px; object-fit: contain; }
    .sidebar-brand-text { line-height: 1.2; }
    .sidebar-brand-text .brand-title {
      font-size: .78rem;
      font-weight: 700;
      color: var(--light-gold);
      text-transform: uppercase;
      letter-spacing: .5px;
    }
    .sidebar-brand-text .brand-sub {
      font-size: .65rem;
      opacity: .7;
    }

    .sidebar-nav {
      flex: 1;
      padding: 1rem 0;
      overflow-y: auto;
    }
    .nav-section-label {
      padding: .4rem 1.2rem;
      font-size: .65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      opacity: .5;
    }
    .nav-item {
      display: flex;
      align-items: center;
      gap: .75rem;
      padding: .65rem 1.2rem;
      cursor: pointer;
      border-radius: 0;
      font-size: .875rem;
      font-weight: 400;
      color: rgba(255,255,255,.75);
      transition: all .15s ease;
      border-left: 3px solid transparent;
      text-decoration: none;
    }
    .nav-item:hover {
      background: rgba(255,255,255,.08);
      color: var(--white);
    }
    .nav-item.active {
      background: rgba(255,255,255,.12);
      color: var(--light-gold);
      border-left-color: var(--light-gold);
      font-weight: 600;
    }
    .nav-item i { width: 18px; text-align: center; font-size: .9rem; }

    .sidebar-footer {
      padding: 1rem;
      border-top: 1px solid rgba(255,255,255,.1);
    }
    .user-card {
      display: flex;
      align-items: center;
      gap: .75rem;
      padding: .5rem .75rem;
      background: rgba(255,255,255,.08);
      border-radius: 8px;
      margin-bottom: .5rem;
    }
    .user-avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: var(--gold);
      color: var(--dark-maroon);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: .875rem;
      flex-shrink: 0;
    }
    .user-card-info { flex: 1; min-width: 0; }
    .user-card-name { font-size: .82rem; font-weight: 600; color: var(--white); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .user-card-role { font-size: .7rem; color: var(--light-gold); }

    /* ─── MAIN CONTENT ────────────────────────────────── */
    #main-content {
      margin-left: var(--sidebar-w);
      flex: 1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ─── TOP HEADER ──────────────────────────────────── */
    #top-header {
      height: var(--header-h);
      background: var(--white);
      border-bottom: 2px solid var(--gray-200);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1.75rem;
      position: sticky;
      top: 0;
      z-index: 50;
      box-shadow: var(--shadow);
    }
    .page-title-wrap h1 {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--maroon);
    }
    .page-title-wrap p { font-size: .8rem; color: var(--gray-500); }
    .header-right { display: flex; align-items: center; gap: 1rem; }
    .header-date {
      font-size: .8rem;
      color: var(--gray-500);
      background: var(--off-white);
      padding: .3rem .75rem;
      border-radius: 20px;
    }
    .notif-btn {
      position: relative;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--gray-500);
      font-size: 1.1rem;
      padding: .4rem;
    }
    .notif-dot {
      position: absolute;
      top: 4px; right: 4px;
      width: 8px; height: 8px;
      background: var(--maroon);
      border-radius: 50%;
      border: 2px solid white;
    }

    /* ─── PAGE BODY ───────────────────────────────────── */
    .page-body { padding: 1.5rem 1.75rem; flex: 1; }

    /* ─── VIEW SECTIONS ───────────────────────────────── */
    .view { display: none; }
    .view.active { display: block; }

    /* ═══════════════════════════════════════════════════
       DASHBOARD VIEW
    ═══════════════════════════════════════════════════ */
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .stat-card {
      background: var(--white);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 1.25rem;
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      border-left: 4px solid var(--maroon);
      transition: transform .15s ease, box-shadow .15s ease;
    }
    .stat-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
    .stat-card.gold { border-left-color: var(--gold); }
    .stat-card.green { border-left-color: #28a745; }
    .stat-card.red-alert { border-left-color: #dc3545; }
    .stat-icon {
      width: 48px; height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      flex-shrink: 0;
    }
    .stat-icon.maroon-icon { background: rgba(128,0,0,.1); color: var(--maroon); }
    .stat-icon.gold-icon   { background: rgba(218,165,32,.12); color: var(--gold); }
    .stat-icon.green-icon  { background: rgba(40,167,69,.1); color: #28a745; }
    .stat-icon.red-icon    { background: rgba(220,53,69,.1); color: #dc3545; }
    .stat-info { flex: 1; }
    .stat-val  { font-size: 1.8rem; font-weight: 700; color: var(--text); line-height: 1; }
    .stat-label{ font-size: .78rem; color: var(--gray-500); margin-top: .2rem; }
    .stat-trend{ font-size: .73rem; margin-top: .3rem; }
    .stat-trend.up   { color: #28a745; }
    .stat-trend.down { color: #dc3545; }

    .charts-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .chart-container { position: relative; height: 260px; }

    .activity-feed { display: flex; flex-direction: column; gap: .6rem; }
    .activity-item {
      display: flex;
      gap: .75rem;
      align-items: flex-start;
      padding: .6rem .75rem;
      border-radius: 8px;
      background: var(--off-white);
    }
    .activity-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      margin-top: 5px;
      flex-shrink: 0;
    }
    .activity-dot.green  { background: #28a745; }
    .activity-dot.blue   { background: #007bff; }
    .activity-dot.yellow { background: var(--gold); }
    .activity-dot.red    { background: #dc3545; }
    .activity-text { font-size: .82rem; color: var(--text); }
    .activity-time { font-size: .72rem; color: var(--gray-500); }

    /* ═══════════════════════════════════════════════════
       TASK BOARD VIEW
    ═══════════════════════════════════════════════════ */
    .board-filters {
      display: flex;
      gap: .75rem;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 1.25rem;
    }
    .board-filters select { min-width: 130px; }

    .kanban-board {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      align-items: start;
    }
    .kanban-col {
      background: var(--gray-100);
      border-radius: var(--radius);
      padding: .75rem;
      min-height: 400px;
    }
    .kanban-col-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: .75rem;
      padding-bottom: .5rem;
      border-bottom: 2px solid;
    }
    .kanban-col-header.pending      { border-color: #ffc107; }
    .kanban-col-header.in_progress  { border-color: #007bff; }
    .kanban-col-header.completed    { border-color: #28a745; }
    .kanban-col-header.cancelled    { border-color: #6c757d; }
    .kanban-col-title {
      font-size: .82rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .5px;
    }
    .kanban-count {
      background: var(--maroon);
      color: var(--white);
      font-size: .68rem;
      font-weight: 600;
      padding: 1px 7px;
      border-radius: 10px;
    }

    .task-card {
      background: var(--white);
      border-radius: 8px;
      padding: .85rem;
      margin-bottom: .6rem;
      box-shadow: 0 1px 4px rgba(0,0,0,.08);
      cursor: pointer;
      transition: transform .12s ease, box-shadow .12s ease;
      border-left: 3px solid transparent;
    }
    .task-card:hover { transform: translateY(-1px); box-shadow: 0 3px 10px rgba(0,0,0,.12); }
    .task-card.priority-urgent { border-left-color: #dc3545; }
    .task-card.priority-high   { border-left-color: #fd7e14; }
    .task-card.priority-medium { border-left-color: #007bff; }
    .task-card.priority-low    { border-left-color: #6c757d; }
    .task-card-title { font-size: .875rem; font-weight: 600; margin-bottom: .4rem; }
    .task-card-desc { font-size: .75rem; color: var(--gray-500); margin-bottom: .5rem; line-height: 1.4; }
    .task-card-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: .3rem;
    }
    .task-assignee {
      display: flex;
      align-items: center;
      gap: .3rem;
      font-size: .72rem;
      color: var(--gray-500);
    }
    .mini-avatar {
      width: 20px; height: 20px;
      border-radius: 50%;
      background: var(--maroon);
      color: white;
      font-size: .55rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .task-due {
      font-size: .7rem;
      color: var(--gray-500);
    }
    .task-due.overdue { color: #dc3545; font-weight: 600; }

    /* ═══════════════════════════════════════════════════
       REPORTS VIEW
    ═══════════════════════════════════════════════════ */
    .reports-layout {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 1.25rem;
      align-items: start;
    }
    .report-list { display: flex; flex-direction: column; gap: .5rem; }
    .report-item {
      padding: .75rem 1rem;
      border-radius: 8px;
      border: 1.5px solid var(--gray-200);
      cursor: pointer;
      transition: all .12s ease;
    }
    .report-item:hover { border-color: var(--maroon); background: var(--off-white); }
    .report-item.selected { border-color: var(--maroon); background: rgba(128,0,0,.04); }
    .report-item-title { font-size: .875rem; font-weight: 600; }
    .report-item-meta { font-size: .73rem; color: var(--gray-500); margin-top: .2rem; }
    .report-preview-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem;
      background: var(--maroon);
      color: white;
      border-radius: 8px 8px 0 0;
      margin: -1.25rem -1.25rem 1.25rem;
    }
    .report-preview-header img { width: 40px; height: 40px; object-fit: contain; }
    .report-stat-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: .75rem;
      margin: 1rem 0;
    }
    .report-stat-box {
      text-align: center;
      padding: .75rem;
      border-radius: 8px;
      background: var(--off-white);
    }
    .report-stat-box .val { font-size: 1.5rem; font-weight: 700; color: var(--maroon); }
    .report-stat-box .lbl { font-size: .72rem; color: var(--gray-500); }

    /* ═══════════════════════════════════════════════════
       USERS VIEW
    ═══════════════════════════════════════════════════ */
    .users-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }

    /* ═══════════════════════════════════════════════════
       TASK DETAIL MODAL
    ═══════════════════════════════════════════════════ */
    .task-detail-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .75rem;
      margin-bottom: 1rem;
    }
    .update-log { display: flex; flex-direction: column; gap: .6rem; max-height: 220px; overflow-y: auto; }
    .update-entry {
      padding: .65rem .85rem;
      border-left: 3px solid var(--maroon);
      background: var(--off-white);
      border-radius: 0 6px 6px 0;
    }
    .update-entry-user { font-size: .75rem; font-weight: 600; color: var(--maroon); }
    .update-entry-text { font-size: .82rem; margin-top: .15rem; }
    .update-entry-time { font-size: .7rem; color: var(--gray-500); margin-top: .2rem; }

    /* ─── TOAST ───────────────────────────────────────── */
    #toast-container {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: .5rem;
    }
    .toast {
      padding: .75rem 1.25rem;
      border-radius: 8px;
      font-size: .875rem;
      font-weight: 500;
      color: white;
      box-shadow: var(--shadow-lg);
      animation: slideIn .2s ease;
    }
    .toast.success { background: #28a745; }
    .toast.error   { background: #dc3545; }
    .toast.info    { background: var(--maroon); }
    @keyframes slideIn {
      from { transform: translateX(40px); opacity: 0; }
      to   { transform: translateX(0);    opacity: 1; }
    }

    /* ─── OVERDUE BANNER ──────────────────────────────── */
    .overdue-banner {
      background: linear-gradient(90deg, #dc3545, #c0392b);
      color: white;
      padding: .55rem 1.75rem;
      font-size: .82rem;
      display: flex;
      align-items: center;
      gap: .5rem;
    }

    /* ─── PROGRESS BAR ────────────────────────────────── */
    .progress-bar-wrap { background: var(--gray-200); border-radius: 20px; height: 8px; overflow: hidden; }
    .progress-bar-fill { height: 100%; border-radius: 20px; background: var(--maroon); transition: width .4s ease; }

    /* ─── RESPONSIVE ──────────────────────────────────── */
    @media (max-width: 1200px) {
      .stat-grid { grid-template-columns: repeat(2, 1fr); }
      .kanban-board { grid-template-columns: repeat(2, 1fr); }
      .charts-grid { grid-template-columns: 1fr; }
      .users-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 900px) {
      :root { --sidebar-w: 0px; }
      #sidebar { display: none; }
      #main-content { margin-left: 0; }
      .reports-layout { grid-template-columns: 1fr; }
    }
  </style>
</head>
