            <option value="1">Group 1</option>
            <option value="2">Group 2</option>
            <option value="3">Group 3</option>
          </select>
          <select class="form-control" id="filter-priority" onchange="renderBoard()">
            <option value="">All Priorities</option>
            <option value="urgent">Urgent</option>
            <option value="high">High</option>
            <option value="medium">Medium</option>
            <option value="low">Low</option>
          </select>
          <select class="form-control" id="filter-assignee" onchange="renderBoard()">
            <option value="">All Assignees</option>
          </select>
          <button class="btn btn-ghost btn-sm" onclick="clearFilters()"><i class="fas fa-times"></i> Clear</button>
          <div style="flex:1"></div>
          <button class="btn btn-primary btn-sm admin-only" onclick="showAddTask()">
            <i class="fas fa-plus"></i> New Task
