              <table>
                <thead><tr><th>Group</th><th>Members</th><th>Leader</th><th>Actions</th></tr></thead>
                <tbody id="groups-body"></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

    </div><!-- end page-body -->
  </div><!-- end main-content -->
</div><!-- end app -->

