      </div>
      <div class="nav-item" onclick="navigate('tasks')">
        <i class="fas fa-tasks"></i> Task Board
      </div>
      <div class="nav-item" onclick="navigate('my-tasks')">
        <i class="fas fa-clipboard-list"></i> My Tasks
      </div>
      <div class="nav-section-label" id="admin-label" style="margin-top:.5rem">Management</div>
      <div class="nav-item admin-only" onclick="navigate('reports')">
        <i class="fas fa-chart-bar"></i> Reports
      </div>
      <div class="nav-item admin-only" onclick="navigate('users')">
        <i class="fas fa-users"></i> Users & Groups
      </div>
    </div>

    <div class="sidebar-footer">
      <div class="user-card">
        <div class="user-avatar" id="sidebar-avatar">MP</div>
        <div class="user-card-info">
          <div class="user-card-name" id="sidebar-name">Mark Pabalan</div>
          <div class="user-card-role" id="sidebar-role">Administrator</div>
        </div>
      </div>
      <button class="btn btn-ghost w-full btn-sm" onclick="handleLogout()">
        <i class="fas fa-sign-out-alt"></i> Logout
      </button>
    </div>
  </nav>

  <!-- MAIN CONTENT -->
  <div id="main-content">

    <!-- OVERDUE BANNER -->
    <div class="overdue-banner" id="overdue-banner">
      <i class="fas fa-exclamation-circle"></i>
      <span>2 tasks are overdue. <a href="#" onclick="navigate('tasks')" style="color:white;font-weight:700">View Tasks</a></span>
    </div>

    <!-- TOP HEADER -->
    <div id="top-header">
      <div class="page-title-wrap">
        <h1 id="page-title">Dashboard</h1>
        <p id="page-sub">Welcome back, Mark</p>
      </div>
      <div class="header-right">
        <div class="header-date" id="header-date"></div>
        <button class="notif-btn" onclick="showNotifications()">
          <i class="fas fa-bell"></i>
          <span class="notif-dot"></span>
        </button>
        <button class="btn btn-primary btn-sm admin-only" id="header-action-btn" onclick="showAddTask()">
          <i class="fas fa-plus"></i> Add Task
        </button>
      </div>
    </div>

    <!-- PAGE BODY -->
    <div class="page-body">

      <!-- ── DASHBOARD ── -->
      <div id="view-dashboard" class="view active">
        <div class="stat-grid">
          <div class="stat-card">
            <div class="stat-icon maroon-icon"><i class="fas fa-list-check"></i></div>
            <div class="stat-info">
              <div class="stat-val">18</div>
              <div class="stat-label">Total Tasks</div>
              <div class="stat-trend up"><i class="fas fa-arrow-up"></i> 3 this week</div>
            </div>
          </div>
          <div class="stat-card green">
            <div class="stat-icon green-icon"><i class="fas fa-check-circle"></i></div>
            <div class="stat-info">
              <div class="stat-val">7</div>
              <div class="stat-label">Completed</div>
              <div class="stat-trend up"><i class="fas fa-arrow-up"></i> 39%</div>
            </div>
          </div>
          <div class="stat-card gold">
            <div class="stat-icon gold-icon"><i class="fas fa-spinner"></i></div>
            <div class="stat-info">
              <div class="stat-val">6</div>
              <div class="stat-label">In Progress</div>
              <div class="stat-trend" style="color:var(--gold)"><i class="fas fa-minus"></i> On track</div>
            </div>
          </div>
          <div class="stat-card red-alert">
            <div class="stat-icon red-icon"><i class="fas fa-exclamation-triangle"></i></div>
            <div class="stat-info">
              <div class="stat-val">2</div>
              <div class="stat-label">Overdue</div>
              <div class="stat-trend down"><i class="fas fa-arrow-up"></i> Needs attention</div>
            </div>
          </div>
        </div>

        <div class="charts-grid">
          <div class="card">
            <div class="card-header">
              <span class="card-title"><i class="fas fa-chart-bar"></i> Tasks by Status per Group</span>
              <select class="form-control" style="width:auto;padding:.3rem .6rem;font-size:.78rem">
                <option>This Week</option>
                <option>This Month</option>
              </select>
            </div>
            <div class="chart-container">
              <canvas id="chart-status"></canvas>
            </div>
          </div>
          <div class="card">
            <div class="card-header">
              <span class="card-title"><i class="fas fa-chart-pie"></i> Priority Split</span>
            </div>
            <div class="chart-container">
              <canvas id="chart-priority"></canvas>
            </div>
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
          <div class="card">
            <div class="card-header">
              <span class="card-title"><i class="fas fa-bolt"></i> Recent Accomplishments</span>
              <button class="btn btn-outline btn-sm" onclick="navigate('tasks')">View All</button>
            </div>
            <div class="activity-feed" id="activity-feed"></div>
          </div>
          <div class="card">
            <div class="card-header">
              <span class="card-title"><i class="fas fa-users"></i> Group Progress</span>
            </div>
