<file path="branched-out-build/frontend/group-reference/css/style.css">
/* 
   Project: PUP OUS – Personnel Daily Accomplishment Report System
   Base Styles extracted from Mockup
*/

@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');
@import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css');

:root {
  --maroon:       #800000;
  --dark-maroon:  #5a0000;
  --deep-maroon:  #3d0000;
  --gold:         #DAA520;
  --light-gold:   #FFD700;
  --pale-gold:    #fff3cd;
  --white:        #ffffff;
  --off-white:    #f8f4f4;
  --gray-100:     #f4f4f4;
  --gray-200:     #e9ecef;
  --gray-500:     #6c757d;
  --gray-700:     #495057;
  --text:         #2d2d2d;
  --sidebar-w:    260px;
  --header-h:     64px;
  --radius:       10px;
  --radius-lg:    24px;
  --shadow:       0 2px 12px rgba(0,0,0,.10);
  --shadow-lg:    0 4px 24px rgba(0,0,0,.15);
}

*, *::before, *::after { 
  box-sizing: border-box; 
  margin: 0; 
  padding: 0; 
}

body {
  font-family: 'Poppins', sans-serif;
  background: var(--off-white);
  color: var(--text);
  min-height: 100vh;
  line-height: 1.6;
}

/* ─── UTILITY ─────────────────────────────────────── */
.hidden { display: none !important; }
.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.gap-1 { gap: .25rem; }
.gap-2 { gap: .5rem; }
.gap-3 { gap: .75rem; }
.gap-4 { gap: 1rem; }
.mt-1 { margin-top: .25rem; }
.mt-2 { margin-top: .5rem; }
.mt-3 { margin-top: .75rem; }
.mt-4 { margin-top: 1rem; }
.w-full { width: 100%; }
.text-sm { font-size: .85rem; }
.text-xs { font-size: .75rem; }
.fw-600 { font-weight: 600; }
.fw-700 { font-weight: 700; }
.color-maroon { color: var(--maroon); }
.color-gold { color: var(--gold); }
.color-gray { color: var(--gray-500); }

/* ─── BUTTONS ─────────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  padding: .5rem 1.1rem;
  border: none;
  border-radius: var(--radius);
  font-family: inherit;
  font-size: .875rem;
  font-weight: 500;
  cursor: pointer;
  transition: all .15s ease;
  text-decoration: none;
}

.btn-primary { 
  background: var(--maroon); 
  color: var(--white); 
}
.btn-primary:hover { 
  background: var(--dark-maroon); 
}

.btn-gold { 
  background: var(--gold); 
  color: var(--white); 
}
.btn-gold:hover { 
  background: #b8860b; 
}

.btn-outline {
  background: transparent;
  color: var(--maroon);
  border: 1.5px solid var(--maroon);
}
.btn-outline:hover { 
  background: var(--maroon); 
  color: var(--white); 
}

/* ─── CARD ────────────────────────────────────────── */
.card {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 1.25rem;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1rem;
  padding-bottom: .75rem;
  border-bottom: 2px solid var(--off-white);
}

.card-title {
  font-size: 1rem;
  font-weight: 600;
  color: var(--maroon);
}

/* ─── FORM ELEMENTS ───────────────────────────────── */
.form-group { 
  display: flex; 
  flex-direction: column; 
  gap: .3rem; 
  margin-bottom: 1rem;
}

.form-label { 
  font-size: .82rem; 
  font-weight: 500; 
  color: var(--gray-700); 
}

.form-control {
  padding: .55rem .85rem;
  border: 1.5px solid var(--gray-200);
  border-radius: 8px;
  font-family: inherit;
  font-size: .875rem;
  color: var(--text);
  background: var(--white);
  transition: border-color .15s ease;
  outline: none;
}

.form-control:focus { 
  border-color: var(--maroon); 
}

/* ─── LOGIN BOX ───────────────────────────────────── */
.login-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--deep-maroon) 0%, var(--maroon) 50%, #a00000 100%);
  padding: 1rem;
}

.login-box {
  background: var(--white);
  border-radius: 16px;
  box-shadow: 0 8px 40px rgba(0,0,0,.35);
  padding: 2.5rem 2rem;
  width: 100%;
  max-width: 420px;
  text-align: center;
}

.login-logo {
  width: 90px;
  height: 90px;
  object-fit: contain;
  margin-bottom: .75rem;
}

/* ─── BADGES ──────────────────────────────────────── */
.badge {
  display: inline-block;
  padding: 2px 10px;
  border-radius: 20px;
  font-size: .72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .4px;
}
.badge-pending     { background: #fff3cd; color: #856404; }
.badge-in_progress { background: #cce5ff; color: #004085; }
.badge-completed   { background: #d4edda; color: #155724; }
.badge-cancelled   { background: #f8d7da; color: #721c24; }
.badge-urgent      { background: #f8d7da; color: #721c24; }
.badge-admin       { background: var(--pale-gold); color: var(--dark-maroon); }

/* ─── TABLE ───────────────────────────────────────── */
.table-wrap { overflow-x: auto; margin-top: 1rem; }
table { width: 100%; border-collapse: collapse; }
thead tr { background: var(--maroon); color: var(--white); }
thead th { padding: .75rem 1rem; text-align: left; font-size: .82rem; font-weight: 500; }
tbody tr { border-bottom: 1px solid var(--gray-200); }
tbody tr:hover { background: var(--off-white); }
tbody td { padding: .7rem 1rem; font-size: .875rem; }

/* ─── MODAL ───────────────────────────────────────── */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,.45);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}
.modal {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow-lg);
  width: 100%;
  max-width: 560px;
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.1rem 1.5rem;
  background: var(--maroon);
  color: var(--white);
  border-radius: var(--radius) var(--radius) 0 0;
}

/* ─── LANDING PAGE COMPONENTS ─────────────────────── */

/* Navigation Bar */
.navbar {
  height: 70px;
  background: var(--white);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 5%;
  box-shadow: var(--shadow);
  position: sticky;
  top: 0;
  z-index: 1000;
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.nav-logo img {
  height: 50px;
}

.nav-links {
  display: flex;
  gap: 2rem;
  list-style: none;
}

.nav-links a {
  text-decoration: none;
  color: var(--text);
  font-weight: 500;
  font-size: 0.9rem;
  transition: color 0.3s;
}

.nav-links a:hover {
  color: var(--maroon);
}

/* Hero Section */
.hero {
  padding: 4rem 5%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 4rem;
  background: white;
}

.hero-content {
  flex: 1;
}

.hero-title {
  font-size: 2.5rem;
  font-weight: 700;
  color: var(--maroon);
  line-height: 1.2;
  margin-bottom: 1.5rem;
}

.hero-description {
  font-size: 1.1rem;
  color: var(--gray-500);
  margin-bottom: 2rem;
  max-width: 600px;
}

.hero-image {
  flex: 1;
  text-align: right;
}

.hero-image img {
  max-width: 100%;
  border-radius: var(--radius);
  box-shadow: var(--shadow-lg);
}

/* Features Section */
.features {
  padding: 4rem 5%;
  background: var(--off-white);
  text-align: center;
}

.section-title {
  margin-bottom: 3rem;
  color: var(--maroon);
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
