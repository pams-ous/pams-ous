                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="window.MyTasks.closeModal('logUpdateModal')">Cancel</button>
                <button class="btn btn-primary" onclick="window.MyTasks.saveLogUpdate()">Save Update</button>
