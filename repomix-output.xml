    <!-- DELETE CONFIRMATION MODAL -->
    <div class="modal-backdrop" id="deleteModal">
        <div class="modal modal-sm">
            <div class="modal-header" style="background: var(--red-text);">
                <span class="modal-title">Remove Task</span>
                <button class="modal-close" onclick="window.MyTasks.closeModal('deleteModal')"><i
                        class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="confirm-body">
                <i class="fa-solid fa-trash-can"></i>
                <p>Are you sure you want to remove <br><strong id="deleteTaskName"></strong>?</p>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="window.MyTasks.closeModal('deleteModal')">Cancel</button>
                <button class="btn btn-danger" onclick="window.MyTasks.confirmDelete()">Remove</button>
            </div>
        </div>
    </div>

    <!-- Configuration and API Logic -->
    <script src="../js/config.js"></script>
    <script src="../js/api.js"></script>
    <script src="../js/layout.js"></script>
    <script src="../js/my-tasks.js"></script>
</body>

</html>
