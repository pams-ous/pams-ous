    /* ═══════════════════════════════════════════════════
       DASHBOARD VIEW
    ═══════════════════════════════════════════════════ */
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .stat-card {
      background: var(--white);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 1.25rem;
      display: flex;
      align-items: flex-start;
