    }
    .kanban-col-header.pending      { border-color: #ffc107; }
    .kanban-col-header.in_progress  { border-color: #007bff; }
    .kanban-col-header.completed    { border-color: #28a745; }
    .kanban-col-header.cancelled    { border-color: #6c757d; }
    .kanban-col-title {
      font-size: .82rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .5px;
    }
    .kanban-count {
      background: var(--maroon);
      color: var(--white);
      font-size: .68rem;
      font-weight: 600;
      padding: 1px 7px;
      border-radius: 10px;
    }

    .task-card {
      background: var(--white);
      border-radius: 8px;
      padding: .85rem;
      margin-bottom: .6rem;
      box-shadow: 0 1px 4px rgba(0,0,0,.08);
      cursor: pointer;
      transition: transform .12s ease, box-shadow .12s ease;
      border-left: 3px solid transparent;
    }
    .task-card:hover { transform: translateY(-1px); box-shadow: 0 3px 10px rgba(0,0,0,.12); }
    .task-card.priority-urgent { border-left-color: #dc3545; }
    .task-card.priority-high   { border-left-color: #fd7e14; }
    .task-card.priority-medium { border-left-color: #007bff; }
    .task-card.priority-low    { border-left-color: #6c757d; }
    .task-card-title { font-size: .875rem; font-weight: 600; margin-bottom: .4rem; }
    .task-card-desc { font-size: .75rem; color: var(--gray-500); margin-bottom: .5rem; line-height: 1.4; }
    .task-card-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: .3rem;
    }
    .task-assignee {
      display: flex;
      align-items: center;
      gap: .3rem;
      font-size: .72rem;
      color: var(--gray-500);
    }
    .mini-avatar {
      width: 20px; height: 20px;
      border-radius: 50%;
      background: var(--maroon);
      color: white;
      font-size: .55rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .task-due {
      font-size: .7rem;
      color: var(--gray-500);
    }
    .task-due.overdue { color: #dc3545; font-weight: 600; }

    /* ═══════════════════════════════════════════════════
       REPORTS VIEW
    ═══════════════════════════════════════════════════ */
    .reports-layout {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 1.25rem;
      align-items: start;
    }
    .report-list { display: flex; flex-direction: column; gap: .5rem; }
    .report-item {
      padding: .75rem 1rem;
      border-radius: 8px;
      border: 1.5px solid var(--gray-200);
      cursor: pointer;
      transition: all .12s ease;
    }
    .report-item:hover { border-color: var(--maroon); background: var(--off-white); }
    .report-item.selected { border-color: var(--maroon); background: rgba(128,0,0,.04); }
    .report-item-title { font-size: .875rem; font-weight: 600; }
    .report-item-meta { font-size: .73rem; color: var(--gray-500); margin-top: .2rem; }
    .report-preview-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem;
      background: var(--maroon);
      color: white;
      border-radius: 8px 8px 0 0;
      margin: -1.25rem -1.25rem 1.25rem;
    }
    .report-preview-header img { width: 40px; height: 40px; object-fit: contain; }
    .report-stat-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: .75rem;
      margin: 1rem 0;
    }
    .report-stat-box {
      text-align: center;
      padding: .75rem;
      border-radius: 8px;
      background: var(--off-white);
    }
    .report-stat-box .val { font-size: 1.5rem; font-weight: 700; color: var(--maroon); }
    .report-stat-box .lbl { font-size: .72rem; color: var(--gray-500); }

    /* ═══════════════════════════════════════════════════
       USERS VIEW
    ═══════════════════════════════════════════════════ */
    .users-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }

    /* ═══════════════════════════════════════════════════
       TASK DETAIL MODAL
    ═══════════════════════════════════════════════════ */
    .task-detail-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .75rem;
      margin-bottom: 1rem;
    }
    .update-log { display: flex; flex-direction: column; gap: .6rem; max-height: 220px; overflow-y: auto; }
    .update-entry {
      padding: .65rem .85rem;
      border-left: 3px solid var(--maroon);
      background: var(--off-white);
      border-radius: 0 6px 6px 0;
    }
    .update-entry-user { font-size: .75rem; font-weight: 600; color: var(--maroon); }
    .update-entry-text { font-size: .82rem; margin-top: .15rem; }
    .update-entry-time { font-size: .7rem; color: var(--gray-500); margin-top: .2rem; }

    /* ─── TOAST ───────────────────────────────────────── */
    #toast-container {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: .5rem;
    }
    .toast {
      padding: .75rem 1.25rem;
      border-radius: 8px;
      font-size: .875rem;
      font-weight: 500;
      color: white;
      box-shadow: var(--shadow-lg);
      animation: slideIn .2s ease;
    }
    .toast.success { background: #28a745; }
    .toast.error   { background: #dc3545; }
    .toast.info    { background: var(--maroon); }
    @keyframes slideIn {
      from { transform: translateX(40px); opacity: 0; }
      to   { transform: translateX(0);    opacity: 1; }
    }

    /* ─── OVERDUE BANNER ──────────────────────────────── */
    .overdue-banner {
      background: linear-gradient(90deg, #dc3545, #c0392b);
      color: white;
      padding: .55rem 1.75rem;
      font-size: .82rem;
      display: flex;
      align-items: center;
      gap: .5rem;
    }

    /* ─── PROGRESS BAR ────────────────────────────────── */
    .progress-bar-wrap { background: var(--gray-200); border-radius: 20px; height: 8px; overflow: hidden; }
    .progress-bar-fill { height: 100%; border-radius: 20px; background: var(--maroon); transition: width .4s ease; }

    /* ─── RESPONSIVE ──────────────────────────────────── */
    @media (max-width: 1200px) {
      .stat-grid { grid-template-columns: repeat(2, 1fr); }
      .kanban-board { grid-template-columns: repeat(2, 1fr); }
      .charts-grid { grid-template-columns: 1fr; }
      .users-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 900px) {
      :root { --sidebar-w: 0px; }
      #sidebar { display: none; }
      #main-content { margin-left: 0; }
      .reports-layout { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

