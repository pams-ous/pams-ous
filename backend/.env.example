# PAMS-OUS Backend — environment template
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- Server ---
PORT=3000
# Change the addresses to the host's IP for the actual deployment
FRONTEND_ORIGIN=http://127.0.0.1:5500
BACKEND_ORIGIN=http://127.0.0.1:3000

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=people

# --- Gmail SMTP (OTP delivery) ---
# Generate the App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification on the Google account).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=pupouspams@gmail.com
SMTP_PASSWORD=insert-16char-app-password
SMTP_FROM=PUP OUS PAMS <pupouspams@gmail.com>

# --- OTP ---
OTP_CODE_LENGTH=6
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
# How the plaintext code is delivered:
#   email   (default) — send via Gmail SMTP. No plaintext is ever stored.
#   console           — DEV ONLY. Skip email; print to nodemon stdout and store
#                       the plaintext code in otp_codes.payload.__dev_code so it
#                       can be read from MySQL. Use while testing locally.
#   both              — Send the email AND log/store locally.
OTP_DELIVERY=email

# Super‑Admin
SUPERADMIN_EMAIL=superadmin@local.test
SUPERADMIN_PASSWORD=supersecret

# --- SMS (stubbed; pick a provider later) ---
# SMS_PROVIDER=semaphore
# SEMAPHORE_API_KEY=

# --- JWT ---
# Generate a secure secret using: openssl rand -base64 32
# Prerequisites:
#   - macOS: pre-installed.
#   - Windows: use Git Bash or WSL (install Git for Windows).
# Run this in your terminal (macOS Terminal, or Git Bash/WSL on Windows).
JWT_SECRET=your_jwt_secret_here

